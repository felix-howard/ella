---
interface Props {
  name: string;
  headlineRole?: string;
  role: string;
  image?: string;
  bio: string;
  details?: readonly string[];
}

const { name, headlineRole, role, image, bio, details } = Astro.props;
const supportingRole = headlineRole === role ? undefined : role;
const initials = name
  .split(" ")
  .map((part) => part.charAt(0))
  .join("")
  .slice(0, 2);
const bioParagraphs = [bio, ...(details ?? [])];
---

<article class="service-card overflow-hidden">
  {image && (
    <img
      src={image}
      alt={`${name} portrait`}
      width="480"
      height="560"
      class="aspect-[6/7] w-full object-cover object-top"
      loading="lazy"
    />
  )}
  {!image && (
    <div class="flex min-h-32 items-center gap-4 border-b border-neutral-border bg-gradient-to-br from-primary-50 to-white p-6">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary-700 text-lg font-bold text-white shadow-lg shadow-primary-900/15" aria-hidden="true">
        {initials}
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-700">Advisor support</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Named team contact</p>
      </div>
    </div>
  )}
  <div class="p-6">
    <h3 class="break-words text-lg font-semibold leading-7 text-slate-950">
      {name}{headlineRole && <span class="text-primary-700">, {headlineRole}</span>}
    </h3>
    {supportingRole && (
      <p class="mt-2 inline-flex max-w-full whitespace-normal rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold leading-5 text-primary-700">{supportingRole}</p>
    )}
    <div class:list={[
      "space-y-3",
      supportingRole ? "mt-4" : "mt-3",
    ]}>
      {bioParagraphs.map((item) => (
        <p class="break-words text-sm leading-6 text-slate-600">{item}</p>
      ))}
    </div>
  </div>
</article>
