---
import {
  clientExperienceStages,
  overpaymentReasons,
  serviceDeliverables,
} from "@/config/tax-advisory-presentation";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div data-animate="fade-up">
      <p class="text-lg text-slate-400">Tax advisory services</p>
      <h2 class="mt-1 font-heading text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">
        Client experience
      </h2>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-5" data-stagger>
      {clientExperienceStages.map((stage) => (
        <article class="text-center" data-animate="fade-up">
          <p class="font-heading text-6xl font-bold leading-none text-slate-950 sm:text-7xl">
            {Number(stage.number)}
          </p>
          <div class="mt-8 flex min-h-[132px] items-center justify-center rounded-lg border border-primary-100 bg-primary-50 p-4 shadow-sm">
            <div>
              <h3 class="font-heading text-lg font-bold text-slate-950">{stage.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{stage.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-20 grid gap-5 lg:grid-cols-3" data-stagger>
      {serviceDeliverables.map((deliverable) => (
        <article class="rounded-lg border-2 border-slate-900 bg-sky-50 p-6 text-center shadow-sm" data-animate="fade-up">
          <h3 class="font-heading text-2xl font-bold text-slate-950">{deliverable.title}</h3>
          <div class="mt-3 flex flex-wrap justify-center gap-2">
            {deliverable.highlights.map((item) => (
              <span class="bg-cyan-300 px-2 py-1 text-lg font-semibold leading-none text-slate-950">
                {item}
              </span>
            ))}
          </div>
          <p class="mt-5 text-base font-medium leading-7 text-slate-900">{deliverable.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-16 rounded-lg border border-slate-200 bg-slate-50 p-6 sm:p-8" data-animate="fade-up">
      <h3 class="font-heading text-3xl font-bold text-slate-950">
        Most clients are overpaying in taxes
      </h3>
      <p class="mt-3 text-center font-heading text-3xl font-bold text-red-600">
        Reasons for overpayment
      </p>
      <div class="mt-8 grid gap-5 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div class="rounded-lg border-2 border-slate-900 bg-green-100 p-6 text-center">
          <ul class="grid gap-3 text-2xl font-semibold leading-tight text-slate-950">
            {overpaymentReasons.slice(0, 4).map((reason) => <li>{reason.title}</li>)}
          </ul>
        </div>
        <div class="rounded-lg border-2 border-slate-900 bg-green-100 p-6 text-center">
          <p class="text-2xl font-semibold leading-tight text-slate-950">
            {overpaymentReasons[4].title} to claim a tax strategy on the return
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
