---
import { helpPromises, heroMetrics } from "@/config/tax-advisory-presentation";
---

<section class="relative overflow-hidden section-dark pt-24 pb-14 text-white sm:pt-28 lg:pb-16">
  <div class="absolute inset-x-0 top-0 h-px bg-white/20" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border border-white/10 bg-white p-6 text-slate-950 shadow-2xl shadow-slate-950/30 sm:p-10 lg:p-14" data-animate="fade-up">
      <div class="grid gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary-700">
            Private tax advisory, audit detection, and compliance planning
          </p>
          <h1 class="mt-4 font-heading text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl xl:text-6xl">
            We will help you
          </h1>
          <p class="mt-6 max-w-xl text-base leading-7 text-slate-600 sm:text-lg">
            A focused planning review that ties tax strategies, audit-ready records,
            compliance responsibilities, implementation steps, and filing timeline together.
          </p>
          <dl class="mt-8 grid gap-3 sm:grid-cols-3">
            {heroMetrics.map((metric) => (
              <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                <dt class="font-heading text-3xl font-bold leading-none text-primary-700">
                  {metric.value}
                </dt>
                <dd class="mt-2 text-xs font-semibold uppercase leading-5 tracking-[0.12em] text-slate-500">
                  {metric.label}
                </dd>
              </div>
            ))}
          </dl>
        </div>

        <ul class="grid gap-4">
          {helpPromises.map((item) => (
            <li class="flex gap-4 rounded-lg border border-slate-200 bg-white p-5 text-base font-semibold leading-7 text-slate-900 shadow-sm shadow-slate-950/5 sm:text-lg">
              <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-primary-600" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
