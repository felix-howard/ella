---
import { partnershipRows } from "@/config/tax-advisory-presentation";
---

<section class="bg-primary-950 py-16 text-white sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div data-animate="fade-up">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-200 sm:text-sm">
          Client partnership
        </p>
        <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">
          Next steps work best when both sides stay accountable.
        </h2>
        <p class="mt-5 text-base leading-7 text-primary-50/80">
          Ella sends the request list, reviews documents, builds the plan, and
          presents recommendations. Clients provide facts, elect strategies, and
          follow through before deadlines.
        </p>
        <a
          href="https://www.facebook.com/my.ella.tax/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex min-h-[44px] cursor-pointer items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-primary-950 shadow-sm transition hover:bg-primary-50 motion-safe:hover:-translate-y-0.5 motion-safe:active:translate-y-0 motion-safe:active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          Message us on Facebook
        </a>
        <p class="mt-3 max-w-sm text-sm leading-6 text-primary-50/70">
          Do not send private tax documents through Facebook. Ella will provide
          secure request links.
        </p>
      </div>

      <div class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.04]" data-animate="fade-up">
        <div class="hidden grid-cols-2 border-b border-white/10 bg-white/[0.06] text-sm font-semibold uppercase tracking-[0.14em] text-primary-100 sm:grid">
          <div class="p-4">Ella does</div>
          <div class="border-l border-white/10 p-4">Client does</div>
        </div>
        {partnershipRows.map((row) => (
          <div class="grid grid-cols-1 border-b border-white/10 last:border-b-0 sm:grid-cols-2">
            <div class="p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary-100 sm:hidden">
                Ella does
              </p>
              <p class="mt-2 text-sm leading-6 text-white sm:mt-0">{row.ella}</p>
            </div>
            <div class="border-white/10 p-4 sm:border-l">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary-100 sm:hidden">
                Client does
              </p>
              <p class="mt-2 text-sm leading-6 text-primary-50/80 sm:mt-0">{row.client}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
