---
/**
 * Site-wide footer with business facts, navigation links, and legal/social.
 */
import { navLinks, legalLinks } from "@/config/navigation";
import { siteConfig } from "@/config/site";

const hasLinkedIn = siteConfig.linkedIn !== "";
const hasFacebook = siteConfig.facebook !== "";
---

<footer class="border-t border-white/10 bg-surface-dark py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Column 1: Logo & tagline -->
      <div>
        <a href="/" class="focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500">
          <img src="/ella-logo.png" alt={siteConfig.name} class="h-8 object-contain brightness-0 invert" />
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-primary-50/70">
          Online tax preparation, bookkeeping, and advisory support for individuals and small businesses.
        </p>
        <address class="mt-4 not-italic text-sm leading-relaxed text-primary-50/70">
          <a class="block transition-colors hover:text-primary-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400" href={siteConfig.contact.phoneHref}>
            {siteConfig.contact.phone}
          </a>
          <a class="block transition-colors hover:text-primary-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400" href={siteConfig.contact.emailHref}>
            {siteConfig.contact.email}
          </a>
          <span class="block">{siteConfig.contact.address.streetAddress}</span>
          <span class="block">
            {siteConfig.contact.address.addressLocality}, {siteConfig.contact.address.addressRegion} {siteConfig.contact.address.postalCode}
          </span>
        </address>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-50">
          Services
        </h3>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-primary-50/70">
          Individual tax prep, business returns, bookkeeping, cleanup, payroll coordination, tax notices, and advisory.
        </p>
      </div>

      <!-- Column 3: Navigation, Legal & Social -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-50">
          Navigation
        </h3>
        <ul class="mt-3 flex flex-col gap-1">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-block py-2 text-sm text-primary-50/70 transition-colors hover:text-primary-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="mt-6 text-sm font-semibold uppercase tracking-wider text-primary-50">
          Legal
        </h3>
        <ul class="mt-3 flex flex-col gap-1">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-block py-2 text-sm text-primary-50/70 transition-colors hover:text-primary-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Social icons (only render if URLs configured) -->
        {(hasLinkedIn || hasFacebook) && (
          <div class="mt-6 flex gap-2">
            {hasFacebook && (
              <a
                href={siteConfig.facebook}
                class="flex h-11 w-11 min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center rounded-full text-primary-50/60 transition-colors hover:bg-white/5 hover:text-primary-300 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
                aria-label="Facebook"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              </a>
            )}
            {hasLinkedIn && (
              <a
                href={siteConfig.linkedIn}
                class="flex h-11 w-11 min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center rounded-full text-primary-50/60 transition-colors hover:bg-white/5 hover:text-primary-300 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
                aria-label="LinkedIn"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-white/10 pt-6">
      <p class="text-center text-sm text-primary-50/50">
        &copy; {new Date().getFullYear()} {siteConfig.legalName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
