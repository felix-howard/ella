---
/**
 * Calculator form — Sections B-E (add-on services).
 * Cash Plan, Audit Protection, One-time services, Sales tax monitoring.
 * Inputs expose `data-calc-input` keys matching `CalcInput` (phase 01).
 */
import {
  AUDIT_PROTECTION,
  CASH_PLAN,
  ONE_TIME,
  SALES_TAX_MONITORING_MONTHLY,
} from "@/config/pricing";
import {
  chevronSvgCls,
  headingCls,
  hintCls,
  inputCls,
  labelCls,
  sectionCls,
} from "./calculator-form-styles";

const oneTimeRows: Array<{
  key: keyof typeof ONE_TIME;
  label: string;
  price: number;
  hint?: string;
}> = [
  { key: "startLlc", label: "Start LLC", price: ONE_TIME.startLlc, hint: "Excludes state filing fee (paid separately)" },
  { key: "holdingLlcNew", label: "Holding LLC (new)", price: ONE_TIME.holdingLlcNew },
  { key: "holdingLlcModify", label: "Holding LLC (modify)", price: ONE_TIME.holdingLlcModify },
  { key: "personalTaxReturn", label: "Personal tax return", price: ONE_TIME.personalTaxReturn },
  { key: "businessTaxReturn", label: "Business tax return", price: ONE_TIME.businessTaxReturn },
];
---

<!-- Section B — Cash Plan -->
<details class={sectionCls}>
  <summary class="flex cursor-pointer list-none items-center justify-between">
    <div>
      <span class={headingCls}>Cash Plan</span>
      <p class={hintCls}>
        ${CASH_PLAN.setup} setup · ${CASH_PLAN.perEmployeeMonthly}/emp + ${CASH_PLAN.perOwnerMonthly}/owner monthly
      </p>
    </div>
    <svg class={chevronSvgCls} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="mt-4 space-y-4">
    <label class="flex cursor-pointer items-start gap-3">
      <input
        type="checkbox"
        name="cashPlanEnabled"
        data-calc-input="cashPlan.enabled"
        class="mt-1 h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
      />
      <span class="text-sm font-medium text-gray-900">Enable Cash Plan</span>
    </label>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="calc-cash-emp" class={labelCls}>Employees enrolled</label>
        <input
          id="calc-cash-emp"
          type="number"
          name="cashPlanEmployees"
          inputmode="numeric"
          min="0"
          max="500"
          step="1"
          value="0"
          data-calc-input="cashPlan.employees"
          class={inputCls}
        />
      </div>
      <div>
        <label for="calc-cash-own" class={labelCls}>Owners / shareholders</label>
        <input
          id="calc-cash-own"
          type="number"
          name="cashPlanOwners"
          inputmode="numeric"
          min="0"
          max="20"
          step="1"
          value="0"
          data-calc-input="cashPlan.owners"
          class={inputCls}
        />
      </div>
    </div>
  </div>
</details>

<!-- Section C — Audit Protection -->
<div class={sectionCls}>
  <label class="flex cursor-pointer items-start gap-3">
    <input
      type="checkbox"
      name="auditProtection"
      data-calc-input="auditProtection"
      class="mt-1 h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
    />
    <span>
      <span class={headingCls}>Add Audit Protection</span>
      <span class="mt-0.5 block text-sm text-gray-500">
        +${AUDIT_PROTECTION.monthly}/mo · ${AUDIT_PROTECTION.setup} one-time setup
      </span>
    </span>
  </label>
</div>

<!-- Section D — One-time services -->
<details class={sectionCls}>
  <summary class="flex cursor-pointer list-none items-center justify-between">
    <div>
      <span class={headingCls}>One-time services</span>
      <p class={hintCls}>Add LLC formation, tax returns, and other fixed-fee work.</p>
    </div>
    <svg class={chevronSvgCls} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <ul class="mt-4 space-y-3">
    {oneTimeRows.map((row) => (
      <li class="grid gap-2 sm:grid-cols-[1fr_120px] sm:items-center">
        <div>
          <label for={`calc-onetime-${row.key}`} class="text-sm font-medium text-gray-900">
            {row.label}
            <span class="ml-2 text-xs text-gray-500">${row.price.toLocaleString()} each</span>
          </label>
          {row.hint && <p class="text-xs text-gray-500">{row.hint}</p>}
        </div>
        <input
          id={`calc-onetime-${row.key}`}
          type="number"
          name={`oneTime_${row.key}`}
          inputmode="numeric"
          min="0"
          max="20"
          step="1"
          value="0"
          aria-label={`${row.label} quantity`}
          data-calc-input={`oneTime.${row.key}`}
          class={inputCls}
        />
      </li>
    ))}
  </ul>
</details>

<!-- Section E — Ongoing extras -->
<div class={sectionCls}>
  <label for="calc-sales-tax" class={labelCls}>Shops for sales tax monitoring</label>
  <input
    id="calc-sales-tax"
    type="number"
    name="salesTaxShops"
    inputmode="numeric"
    min="0"
    max="100"
    step="1"
    value="0"
    aria-describedby="calc-sales-tax-hint"
    data-calc-input="salesTaxShops"
    class={inputCls}
  />
  <p id="calc-sales-tax-hint" class={hintCls}>
    +${SALES_TAX_MONITORING_MONTHLY}/mo per shop monitored.
  </p>
</div>
