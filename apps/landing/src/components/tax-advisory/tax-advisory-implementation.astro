---
import { implementationTracks } from "@/config/tax-advisory-presentation";
---

<section class="bg-[#f8fafc] py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="max-w-3xl" data-animate="fade-up">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800 sm:text-sm">
        Implementation tasks
      </p>
      <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight text-gray-950 sm:text-4xl">
        Strategy only counts when the required work gets done.
      </h2>
      <p class="mt-5 text-base leading-7 text-gray-600">
        The deck separates advisory from filing by making implementation visible:
        entity decisions, retirement setup, Augusta Rule records, fringe benefits,
        medical planning, and estimate reviews all become tracked tasks.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-stagger>
      {implementationTracks.map((track) => (
        <article
          class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-primary-200 hover:shadow-lg motion-safe:hover:-translate-y-1 sm:p-6"
          data-animate="fade-up"
        >
          <h3 class="font-heading text-xl font-bold text-gray-950">{track.title}</h3>
          <p class="mt-3 text-sm leading-6 text-gray-600">{track.description}</p>
          <ul class="mt-6 grid gap-2">
            {track.tasks.map((task) => (
              <li class="rounded-lg border border-primary-100 bg-primary-50 px-3 py-2 text-sm font-semibold leading-5 text-primary-900">
                {task}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
