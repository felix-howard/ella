---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: readonly FaqItem[];
  includeSchema?: boolean;
}

const { title = "Questions clients ask", items, includeSchema = false } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
const schemaJson = JSON.stringify(schema).replace(/</g, "\\u003c");
---

<section class="bg-white py-16 sm:py-24">
  {includeSchema && <script is:inline type="application/ld+json" set:html={schemaJson}></script>}
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-slate-950 sm:text-4xl font-heading">{title}</h2>
    <div class="mt-8 divide-y divide-sky-100 rounded-lg border border-sky-100 bg-sky-50/40">
      {items.map((item) => (
        <details class="group p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-semibold text-slate-950">
            {item.question}
            <span class="text-primary-700 transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="mt-3 text-sm leading-6 text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
