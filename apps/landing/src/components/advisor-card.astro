---
interface Props {
  name: string;
  role: string;
  image?: string;
  bio: string;
}

const { name, role, image, bio } = Astro.props;
---

<article class="service-card overflow-hidden">
  {image && (
    <img
      src={image}
      alt={name}
      width="480"
      height="360"
      class="aspect-[4/3] w-full object-cover"
      loading="lazy"
    />
  )}
  <div class="p-6">
    <p class="text-lg font-semibold text-slate-950">{name}</p>
    <p class="mt-1 text-sm font-medium text-primary-700">{role}</p>
    <p class="mt-4 text-sm leading-6 text-slate-600">{bio}</p>
  </div>
</article>
