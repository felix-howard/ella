---
/**
 * Pricing page — Ella Tax-specific 3-tier marketing cards + interactive calculator.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import SectionHeading from "@/components/section-heading.astro";
import TierCard from "@/components/pricing/tier-card.astro";
import CalculatorSection from "@/components/pricing/calculator-section.astro";
import OneTimeServicesSection from "@/components/pricing/one-time-services-section.astro";
import ConsultationModal from "@/components/pricing/consultation-modal.astro";
import { breadcrumbSchema } from "@/components/seo/structured-data";
import { pricingTierCards } from "@/config/pricing-page-content";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Pricing", url: `${siteConfig.url}/pricing` },
  ]),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Pricing - Ella Tax | Resolution, Audit Detection, and Compliance"
    description="Transparent pricing for tax resolution, audit detection, compliance, filings, payroll coordination, sales tax, franchise tax, and small business support."
    structuredData={structuredData}
  />

  {/* Internal-only password gate (sessionStorage-backed). Runs before body
      paints to avoid flash of gated content. Not a security boundary — just
      friction for public visitors. */}
  <script is:inline slot="head">
    (function () {
      try {
        if (sessionStorage.getItem("ellaPricingAuth") === "1") {
          document.documentElement.setAttribute("data-pricing-auth", "ok");
        }
      } catch (_e) { /* sessionStorage unavailable — gate stays visible */ }
    })();
  </script>
  <style is:global slot="head">
    html[data-pricing-auth="ok"] #pricing-gate { display: none; }
  </style>

  <!-- Password gate overlay -->
  <div
    id="pricing-gate"
    class="service-section fixed inset-0 z-[100] flex items-center justify-center px-4 py-8 sm:px-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pricing-gate-title"
    aria-describedby="pricing-gate-description"
  >
    <form id="pricing-gate-form" class="service-card w-full max-w-md p-6 shadow-2xl shadow-slate-900/10 sm:p-8">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-primary-700">
        Ella pricing
      </p>
      <h2 id="pricing-gate-title" class="mt-2 text-center text-2xl font-bold text-slate-950 font-heading">
        Internal preview access
      </h2>
      <p id="pricing-gate-description" class="mx-auto mt-3 max-w-xs text-center text-sm leading-6 text-slate-600">
        Enter the preview password to view pricing packages and the calculator.
      </p>
      <label for="pricing-gate-input" class="mt-6 block text-sm font-semibold text-slate-800">
        Password
      </label>
      <input
        id="pricing-gate-input"
        type="password"
        autocomplete="off"
        autofocus
        aria-describedby="pricing-gate-error"
        placeholder="Enter password"
        class="mt-2 w-full rounded-lg border border-neutral-border bg-white px-4 py-3 text-base text-slate-900 placeholder-slate-400 transition focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
      />
      <p id="pricing-gate-error" hidden class="mt-2 text-sm font-medium text-error-500">
        Incorrect password.
      </p>
      <button
        type="submit"
        class="btn-primary mt-5 w-full"
      >
        Continue
      </button>
      <p class="mt-4 text-center text-xs leading-5 text-slate-500">
        This gate is only preview friction, not a security boundary.
      </p>
    </form>
  </div>

  <main>
    <!-- Hero -->
    <section class="service-section border-b border-neutral-border/70 pt-32 pb-16">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <p
          class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary-800"
          data-animate="fade-up"
        >
          Pricing
        </p>
        <h1
          class="text-4xl font-extrabold leading-tight text-slate-950 sm:text-5xl font-heading"
          data-animate="fade-up"
        >
          Packages for tax resolution, audit detection, and compliance
        </h1>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600"
          data-animate="fade-up"
        >
          Transparent pricing built for clients who need clearer tax help,
          stronger audit-ready records, and practical compliance support. Each
          tier shows a typical monthly bundle, then lets you dial in details below.
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row" data-animate="fade-up">
          <a class="btn-primary w-full sm:w-auto" href="#pricing">Compare packages</a>
          <a class="btn-secondary w-full sm:w-auto" href="#calculator">Use calculator</a>
        </div>
      </div>
    </section>

    <!-- Tier cards -->
    <section id="pricing" class="bg-white py-16 sm:py-24" aria-label="Pricing tiers">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Packages"
          title="Start with the plan that matches your tax risk"
          subtitle="Every package can be adjusted in the calculator below. The cards show common monthly bundles, setup fees, audit detection, and included compliance support."
        />
        <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3" data-stagger>
          {pricingTierCards.map((tier) => <TierCard {...tier} />)}
        </div>
      </div>
    </section>

    <!-- Up-front services (tax returns + LLC formation) -->
    <OneTimeServicesSection />

    <!-- Calculator placeholder (phases 03-05 fill this) -->
    <section
      id="calculator"
      class="section-muted py-16 sm:py-24"
      aria-label="Pricing calculator"
    >
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Calculator"
          title="Calculate your exact compliance package"
          subtitle="Enter your business details and we will compute monthly support plus setup and one-time work instantly."
        />
        <div id="calculator-root" class="mt-12" data-animate="fade-up">
          <CalculatorSection />
        </div>
      </div>
    </section>

  </main>

  <ConsultationModal />

  <script>
    import "@/scripts/pricing-calculator";
  </script>

  <script is:inline>
    (function () {
      const form = document.getElementById("pricing-gate-form");
      if (!form) return;
      const input = document.getElementById("pricing-gate-input");
      const err = document.getElementById("pricing-gate-error");
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        if (!input || !err) return;
        if (input.value === "1233") {
          try { sessionStorage.setItem("ellaPricingAuth", "1"); } catch (_e) { /* ignore */ }
          document.documentElement.setAttribute("data-pricing-auth", "ok");
        } else {
          err.hidden = false;
          input.value = "";
          input.focus();
        }
      });
    })();
  </script>
</BaseLayout>
