---
/**
 * Privacy Policy page for Ella Tax Services LLC.
 * Effective April 4th, 2026.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import LegalPageNav from "@/components/legal-page-nav.astro";
import { breadcrumbSchema } from "@/components/seo/structured-data";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Privacy Policy", url: `${siteConfig.url}/privacy` },
  ]),
];
const address = siteConfig.contact.address;
const pageLinks = [
  { href: "#information-we-collect", label: "Information We Collect" },
  { href: "#how-we-use-your-information", label: "How We Use Your Information" },
  { href: "#how-we-share-your-information", label: "How We Share Your Information" },
  { href: "#data-security", label: "Data Security" },
  { href: "#data-retention", label: "Data Retention" },
  { href: "#your-rights-and-choices", label: "Your Rights and Choices" },
  { href: "#cookies-and-tracking-technologies", label: "Cookies and Tracking Technologies" },
  { href: "#third-party-services", label: "Third-Party Services" },
  { href: "#childrens-privacy", label: "Children's Privacy" },
  { href: "#changes-to-this-policy", label: "Changes to This Policy" },
  { href: "#contact-information", label: "Contact Information" },
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Privacy Policy - Ella Tax Services LLC"
    description="Learn how Ella Tax Services LLC collects, uses, discloses, and safeguards your personal information."
    structuredData={structuredData}
  />

  <main class="service-section pt-28 pb-16 sm:pt-32 sm:pb-24">
    <article class="legal-content legal-document service-card mx-auto max-w-4xl px-5 py-8 sm:px-10">
      <h1>Ella Tax Services LLC &ndash; Privacy Policy</h1>
      <p><strong>Effective Date:</strong> April 4th, 2026</p>
      <p>
        Ella Tax Services LLC (&ldquo;Ella Tax Services,&rdquo; &ldquo;we,&rdquo; &ldquo;our,&rdquo; or &ldquo;us&rdquo;) respects your privacy and is committed to protecting your personal information. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our services.
      </p>

      <LegalPageNav links={pageLinks} />

      <hr />

      <h2 id="information-we-collect">1. Information We Collect</h2>
      <p>We may collect the following types of information:</p>

      <h3>a. Personal Information</h3>
      <ul>
        <li>Name, email address, phone number</li>
        <li>Date of birth</li>
        <li>Social Security Number (SSN) or Tax Identification Number (TIN)</li>
        <li>Government-issued identification</li>
      </ul>

      <h3>b. Financial Information</h3>
      <ul>
        <li>Income and tax documents (W-2, 1099, etc.)</li>
        <li>Bank account and payment details</li>
        <li>Business financial records</li>
      </ul>

      <h3>c. Business Information</h3>
      <ul>
        <li>Company name, EIN, and formation details</li>
        <li>Ownership and operational information</li>
      </ul>

      <h3>d. Technical Information</h3>
      <ul>
        <li>IP address</li>
        <li>Device type and browser</li>
        <li>Usage data and interactions with our website, client portal, and online service tools</li>
      </ul>

      <hr />

      <h2 id="how-we-use-your-information">2. How We Use Your Information</h2>
      <p>We use your information to:</p>
      <ul>
        <li>Provide tax preparation and filing services</li>
        <li>Deliver bookkeeping and business services</li>
        <li>Process payments and manage billing</li>
        <li>Communicate with you about your account or services</li>
        <li>Improve our services and user experience</li>
        <li>Comply with legal and regulatory requirements</li>
      </ul>

      <hr />

      <h2 id="how-we-share-your-information">3. How We Share Your Information</h2>
      <p>We do <strong>not sell your personal information</strong>.</p>
      <p>We may share your information with:</p>

      <h3>a. Service Providers</h3>
      <ul>
        <li>Payment processors</li>
        <li>Tax filing software providers</li>
        <li>Cloud storage and hosting services</li>
      </ul>

      <h3>b. Government Authorities</h3>
      <ul>
        <li>IRS and state tax agencies, when required to file your taxes</li>
      </ul>

      <h3>c. Legal Requirements</h3>
      <ul>
        <li>When required by law, regulation, or legal process</li>
      </ul>

      <h3>d. Business Transfers</h3>
      <ul>
        <li>In the event of a merger, sale, or acquisition</li>
      </ul>

      <hr />

      <h2 id="data-security">4. Data Security</h2>
      <p>
        We implement reasonable administrative, technical, and physical safeguards to protect your information. However, no system is completely secure, and we cannot guarantee absolute security.
      </p>

      <hr />

      <h2 id="data-retention">5. Data Retention</h2>
      <p>We retain your information:</p>
      <ul>
        <li>As long as necessary to provide services</li>
        <li>As required for legal, tax, and compliance purposes</li>
      </ul>

      <hr />

      <h2 id="your-rights-and-choices">6. Your Rights and Choices</h2>
      <p>Depending on your location, you may have the right to:</p>
      <ul>
        <li>Access or request a copy of your data</li>
        <li>Correct inaccurate information</li>
        <li>Request deletion of your data (subject to legal requirements)</li>
      </ul>
      <p>
        To exercise your rights, contact us at <a href={siteConfig.contact.emailHref}>{siteConfig.contact.email}</a>.
      </p>

      <hr />

      <h2 id="cookies-and-tracking-technologies">7. Cookies and Tracking Technologies</h2>
      <p>We may use cookies and similar technologies to:</p>
      <ul>
        <li>Improve website functionality</li>
        <li>Analyze traffic and usage patterns</li>
        <li>Enhance user experience</li>
      </ul>
      <p>You can control cookie settings through your browser.</p>

      <hr />

      <h2 id="third-party-services">8. Third-Party Services</h2>
      <p>
        Our services may include links or integrations with third-party providers. We are not responsible for the privacy practices of those third parties.
      </p>

      <hr />

      <h2 id="childrens-privacy">9. Children&rsquo;s Privacy</h2>
      <p>
        Our services are not intended for individuals under 18. We do not knowingly collect personal information from children.
      </p>

      <hr />

      <h2 id="changes-to-this-policy">10. Changes to This Policy</h2>
      <p>
        We may update this Privacy Policy from time to time. Continued use of our services after changes indicates your acceptance of the updated policy.
      </p>

      <hr />

      <h2 id="contact-information">11. Contact Information</h2>
      <p>If you have questions about this Privacy Policy, please contact us:</p>
      <ul>
        <li>Email: <a href={siteConfig.contact.emailHref}>{siteConfig.contact.email}</a></li>
        <li>Phone: <a href={siteConfig.contact.phoneHref}>{siteConfig.contact.phone}</a></li>
        <li>Address: {address.streetAddress}, {address.addressLocality}, {address.addressRegion} {address.postalCode}</li>
        <li>Web: <a href={siteConfig.url}>ella.tax</a></li>
      </ul>
    </article>
  </main>
</BaseLayout>
