---
import {
  clientExperienceStages,
  overpaymentReasons,
  serviceDeliverables,
} from "@/config/tax-advisory-presentation";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="max-w-3xl" data-animate="fade-up">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800">
        Tax advisory services
      </p>
      <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
        Client experience
      </h2>
      <p class="mt-4 text-base leading-7 text-slate-600">
        Each step narrows the work from discovery to implementation, estimates, and filing.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-5" data-stagger>
      {clientExperienceStages.map((stage) => (
        <article class="rounded-lg border border-slate-200 bg-slate-50 p-5 shadow-sm" data-animate="fade-up">
          <p class="font-heading text-4xl font-bold leading-none text-primary-700">
            {Number(stage.number)}
          </p>
          <h3 class="mt-8 font-heading text-lg font-bold text-slate-950">{stage.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{stage.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-20 grid gap-5 lg:grid-cols-3" data-stagger>
      {serviceDeliverables.map((deliverable) => (
        <article class="rounded-lg border border-primary-100 bg-primary-50/70 p-6 shadow-sm" data-animate="fade-up">
          <h3 class="font-heading text-2xl font-bold text-slate-950">{deliverable.title}</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {deliverable.highlights.map((item) => (
              <span class="rounded-full border border-primary-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-primary-800">
                {item}
              </span>
            ))}
          </div>
          <p class="mt-5 text-base leading-7 text-slate-700">{deliverable.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-16 rounded-lg border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8" data-animate="fade-up">
      <h3 class="font-heading text-3xl font-bold text-slate-950">
        Why planning work needs facts and follow-through
      </h3>
      <p class="mt-3 text-base font-semibold uppercase tracking-[0.16em] text-red-700">
        Common planning gaps
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {overpaymentReasons.map((reason) => (
          <article class="rounded-lg border border-slate-200 bg-white p-4">
            <h4 class="font-heading text-base font-bold leading-6 text-slate-950">
              {reason.title}
            </h4>
            <p class="mt-2 text-sm leading-6 text-slate-600">{reason.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
