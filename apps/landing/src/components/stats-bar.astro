---
/**
 * Animated stats bar showing key metrics in a responsive grid.
 * Counter animation wired via data-count attribute (activated by scroll-observer).
 * Aurora/dark theme variant with glowing emerald numbers.
 */
interface StatItem {
  value: number;
  label: string;
  suffix?: string;
}

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 gap-8 md:grid-cols-4" data-stagger>
  {stats.map((stat) => (
    <div class="text-center" data-animate="fade-up">
      <p
        class="text-3xl font-bold text-white sm:text-4xl font-heading"
        style="text-shadow: 0 0 20px rgba(5, 150, 105, 0.6), 0 0 40px rgba(5, 150, 105, 0.3);"
        data-count={stat.value}
        data-suffix={stat.suffix ?? ""}
      >
        0{stat.suffix ?? ""}
      </p>
      <p class="mt-2 text-sm text-gray-400">{stat.label}</p>
    </div>
  ))}
</div>
