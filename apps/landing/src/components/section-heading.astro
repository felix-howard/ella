---
/**
 * Reusable section heading: optional eyebrow label + title (h2) + optional subtitle.
 * Supports left or center alignment.
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { eyebrow, title, subtitle, align = "center" } = Astro.props;

const alignClass = align === "center" ? "text-center" : "text-left";
const subtitleMargin = align === "center" ? "mx-auto" : "";
const titleMargin = align === "center" ? "mx-auto" : "";
---

<div class={alignClass}>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-700">
      {eyebrow}
    </p>
  )}
  <h2 class:list={["mt-3 max-w-3xl text-2xl font-extrabold leading-tight text-slate-950 sm:text-3xl md:text-4xl font-heading", titleMargin]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={["mt-4 max-w-2xl text-base leading-7 text-slate-600", subtitleMargin]}>
      {subtitle}
    </p>
  )}
</div>
