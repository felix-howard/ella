---
import ContactBand from "@/components/contact-band.astro";
import FAQSection from "@/components/faq-section.astro";
import PageHero from "@/components/page-hero.astro";
import SectionHeading from "@/components/section-heading.astro";
import SoftwareFeatureGrid from "@/components/software-feature-grid.astro";
import TrustStrip from "@/components/trust-strip.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import { breadcrumbSchema } from "@/components/seo/structured-data";
import BaseLayout from "@/layouts/base-layout.astro";
import {
  clientProblems,
  ellaApproach,
  onlineFilingHighlights,
  trustItems,
  whyEllaFaq,
} from "@/config/why-ella-data";
import { whySoftwareCards } from "@/config/software-content";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Why Ella", url: `${siteConfig.url}/why-ella` },
  ]),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Why Choose Ella Tax Services - Online Tax Help"
    description="See why individuals, families, and small businesses choose Ella Tax Services for online tax filing, planning, bookkeeping, and advisory support."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="Why Ella Tax Services"
      title="Online tax help for clients who want clarity"
      subtitle="Ella Tax Services combines secure online document sharing with advisor review, practical tax support, and clear next steps for individuals and small businesses."
      primaryCta={{ label: "Start Online Tax Filing", href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: siteConfig.cta.secondaryLabel, href: siteConfig.cta.secondaryHref }}
    />

    <TrustStrip items={trustItems} />

    <SoftwareFeatureGrid
      eyebrow="Online filing workflow"
      title="Convenient online tax filing with real support"
      subtitle="Ella Tax Services gives clients a secure online path for intake, document upload, advisor review, and follow-up."
      cards={whySoftwareCards}
      variant="proof"
    />

    <section class="bg-white py-16 sm:py-24" aria-label="Common tax service challenges">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:px-8">
        <SectionHeading eyebrow="The challenge" title="Tax help gets stressful when context is missing" align="left" />
        <div class="grid gap-4" data-stagger>
          {clientProblems.map((problem, index) => (
            <article class="rounded-lg border border-orange-100 bg-orange-50/50 p-5" data-animate="fade-up">
              <div class="flex items-start gap-4">
                <div class="flex h-11 w-11 flex-none items-center justify-center rounded-lg bg-white text-accent-800 shadow-sm">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={problem.icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-700">Friction {index + 1}</p>
                  <h3 class="mt-2 text-lg font-semibold text-slate-950">{problem.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{problem.description}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-section py-16 sm:py-24" aria-label="Ella Tax Services approach">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="The Ella approach" title="Advisor-supported filing, planning, and business tax support" />
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-stagger>
          {ellaApproach.map((item, index) => (
            <article class:list={[
              "service-card p-6",
              index === 0 ? "lg:col-span-2" : "",
            ]} data-animate="fade-up">
              <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-700 text-white">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-slate-950">{item.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24" aria-label="Online tax filing convenience">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:px-8">
        <SectionHeading
          eyebrow="Online convenience"
          title="Convenient online tax filing with Ella Tax Services"
          subtitle="Start online, upload documents securely, and get advisor-supported next steps while the main workflow stays simple."
          align="left"
        />
        <div class="grid gap-4" data-stagger>
          {onlineFilingHighlights.map((item) => (
            <article class="service-card p-5" data-animate="fade-up">
              <div class="flex items-start gap-4">
                <div class="flex h-11 w-11 flex-none items-center justify-center rounded-lg bg-primary-100 text-primary-700">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-slate-950">{item.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{item.description}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <FAQSection title="Why clients choose Ella" items={whyEllaFaq} includeSchema={true} />
    <ContactBand title="Get online tax help with a clear next step" />
  </main>
</BaseLayout>
