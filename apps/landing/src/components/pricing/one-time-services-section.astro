---
/**
 * Up-front services pricing section — shown below tier cards on pricing page.
 * Surfaces fixed-fee add-ons from the calculator so visitors see up-front costs
 * without touching the calculator.
 */
import SectionHeading from "@/components/section-heading.astro";
import { checkPath } from "@/lib/icons";
import { ONE_TIME } from "@/config/pricing";

const fmt = (n: number) => `$${n.toLocaleString("en-US")}`;

interface ServiceRow {
  label: string;
  price: string;
  note?: string;
}

interface ServiceGroup {
  eyebrow: string;
  title: string;
  items: ServiceRow[];
}

const groups: ServiceGroup[] = [
  {
    eyebrow: "Tax filing",
    title: "Personal filing support",
    items: [
      {
        label: "Personal tax return",
        price: `${fmt(ONE_TIME.personalTaxReturn)} each`,
      },
    ],
  },
  {
    eyebrow: "Company structure",
    title: "LLC formation & changes",
    items: [
      {
        label: "Start LLC",
        price: `${fmt(ONE_TIME.startLlc)} each`,
        note: "Excludes state filing fee (paid separately)",
      },
      {
        label: "Holding LLC (new)",
        price: `${fmt(ONE_TIME.holdingLlcNew)} each`,
      },
      {
        label: "Re-structure LLC basic",
        price: `${fmt(ONE_TIME.holdingLlcModify)} each`,
      },
    ],
  },
];
---

<section
  id="one-time-services"
  class="bg-white pb-16 sm:pb-24"
  aria-label="One-time services pricing"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Up-front services"
      title="Fixed-fee add-ons"
      subtitle="Pay-as-you-go support for personal filings, compliance cleanup, and company structure - no subscription required."
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
      {groups.map((group) => (
        <div
          class="service-card p-6 sm:p-8"
          data-animate="fade-up"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-primary-800">
            {group.eyebrow}
          </p>
          <h3 class="mt-1 text-xl font-semibold text-gray-900">{group.title}</h3>

          <ul class="mt-6 space-y-4">
            {group.items.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="mt-0.5 h-5 w-5 flex-none text-primary-600"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={checkPath} />
                </svg>
                <div class="flex-1">
                  <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                    <span class="text-sm font-medium text-gray-900">
                      {item.label}
                    </span>
                    <span class="text-sm font-semibold text-gray-900">
                      {item.price}
                    </span>
                  </div>
                  {item.note && (
                    <p class="mt-1 text-xs text-gray-500">{item.note}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
