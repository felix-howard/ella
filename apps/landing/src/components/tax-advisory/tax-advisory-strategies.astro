---
import {
  additionalCostStrategyColumns,
  strategyCatalogColumns,
} from "@/config/tax-advisory-presentation";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm" data-animate="fade-up">
      <div class="bg-slate-950 px-6 py-6">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-200">
          Strategy catalog
        </p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">
          Core strategies
        </h2>
      </div>
      <div class="grid gap-8 p-6 sm:p-10 lg:grid-cols-2">
        {strategyCatalogColumns.slice(0, 2).map((column) => (
          <ul class="grid gap-3 text-base leading-6 text-slate-600 sm:text-lg">
            {column.map((strategy) => (
              <li class="flex gap-4">
                <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                <span>{strategy}</span>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <div class="mt-12 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm" data-animate="fade-up">
      <div class="bg-slate-950 px-6 py-6">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-200">
          Strategy catalog
        </p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">
          Additional strategies
        </h2>
      </div>
      <div class="grid gap-8 p-6 sm:p-10 lg:grid-cols-2">
        {strategyCatalogColumns.slice(2).map((column) => (
          <ul class="grid gap-3 text-base leading-6 text-slate-600 sm:text-lg">
            {column.map((strategy) => (
              <li class="flex gap-4">
                <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                <span>{strategy}</span>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <div class="mt-12 rounded-lg border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-10" data-animate="fade-up">
      <h2 class="font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
        Strategies that require additional cost
      </h2>
      <div class="mt-4 h-1 w-32 max-w-full rounded-full bg-primary-500" aria-hidden="true"></div>
      <div class="mt-8 grid gap-8 lg:grid-cols-2">
        {additionalCostStrategyColumns.map((column) => (
          <ul class="grid gap-3 text-base leading-6 text-slate-600 sm:text-lg">
            {column.map((strategy) => (
              <li class="flex gap-4">
                <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                <span>{strategy}</span>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>
  </div>
</section>
