---
/**
 * Pricing page — Ella Tax-specific 3-tier marketing cards + interactive calculator.
 * Phase 02 scope: hero, tier cards row, calculator.
 * Calculator UI + logic wired in subsequent phases (03-05).
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import SectionHeading from "@/components/section-heading.astro";
import TierCard from "@/components/pricing/tier-card.astro";
import CalculatorSection from "@/components/pricing/calculator-section.astro";
import OneTimeServicesSection from "@/components/pricing/one-time-services-section.astro";
import { breadcrumbSchema } from "@/components/seo/structured-data";
import { siteConfig } from "@/config/site";
import {
  TIER_BASIC,
  TIER_PRO,
  TIER_ENTERPRISE,
  PAYROLL,
  AUDIT_PROTECTION,
} from "@/config/pricing";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Pricing", url: `${siteConfig.url}/pricing` },
  ]),
];

/* ---------- Marketing tier card data (display only, sourced from constants) ---------- */

/*
 * Marketing price = bundle of tier-base + typical add-ons.
 * `breakdown` lets users see the exact math (matches the calculator below).
 * All three tiers reconcile exactly to their headline monthly total.
 */

const tierCards = [
  {
    id: "basic" as const,
    name: TIER_BASIC.label,
    tagline: TIER_BASIC.tagline,
    monthlyPrice: TIER_BASIC.marketingMonthly,
    priceNote: "typical salon setup",
    setupFee: TIER_BASIC.setup,
    bullets: TIER_BASIC.bullets,
    breakdownHeading: "How it adds up",
    breakdown: [
      {
        label: `Basic tier (\u2264${TIER_BASIC.maxNec1099} workers)`,
        amount: TIER_BASIC.monthly,
      },
      { label: "+ Payroll base", amount: PAYROLL.baseMonthly },
    ],
    popular: false,
  },
  {
    id: "pro" as const,
    name: TIER_PRO.label,
    tagline: TIER_PRO.tagline,
    monthlyPrice: TIER_PRO.marketingMonthly,
    priceNote: "typical salon setup",
    setupFee: TIER_PRO.setup,
    bullets: TIER_PRO.bullets,
    breakdownHeading: "How it adds up",
    breakdown: [
      {
        label: `Pro tier (${TIER_BASIC.maxNec1099 + 1}\u2013${TIER_PRO.maxNec1099} workers)`,
        amount: TIER_PRO.monthly,
      },
      { label: "+ Payroll base", amount: PAYROLL.baseMonthly },
    ],
    popular: true,
  },
  {
    id: "vip" as const,
    name: TIER_ENTERPRISE.marketingLabel,
    tagline: TIER_ENTERPRISE.tagline,
    monthlyPrice: TIER_ENTERPRISE.marketingMonthly,
    priceNote: "typical premium bundle",
    // Setup fee varies per VIP engagement — shown as custom note in TierCard.
    setupNote: "Custom setup quote",
    bullets: TIER_ENTERPRISE.bullets,
    breakdownHeading: "How it adds up",
    breakdown: [
      {
        label: `Pro tier (${TIER_BASIC.maxNec1099 + 1}\u2013${TIER_PRO.maxNec1099} workers)`,
        amount: TIER_PRO.monthly,
      },
      { label: "+ Payroll base", amount: PAYROLL.baseMonthly },
      { label: "+ Audit Protection", amount: AUDIT_PROTECTION.monthly },
    ],
    popular: false,
  },
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Pricing — Ella Tax | Transparent Plans for Salons & Small Businesses"
    description="Transparent pricing for nail salons, small shops, and LLCs. Pick a tier, then use our calculator to get an exact monthly + setup quote."
    structuredData={structuredData}
  />

  {/* Internal-only password gate (sessionStorage-backed). Runs before body
      paints to avoid flash of gated content. Not a security boundary — just
      friction for public visitors. */}
  <script is:inline slot="head">
    (function () {
      try {
        if (sessionStorage.getItem("ellaPricingAuth") === "1") {
          document.documentElement.setAttribute("data-pricing-auth", "ok");
        }
      } catch (_e) { /* sessionStorage unavailable — gate stays visible */ }
    })();
  </script>
  <style is:global slot="head">
    html[data-pricing-auth="ok"] #pricing-gate { display: none; }
  </style>

  <!-- Password gate overlay -->
  <div
    id="pricing-gate"
    class="fixed inset-0 z-[100] flex items-center justify-center bg-white px-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pricing-gate-title"
  >
    <form id="pricing-gate-form" class="w-full max-w-sm">
      <h2 id="pricing-gate-title" class="mb-2 text-center text-xl font-semibold text-gray-900">
        Internal access
      </h2>
      <p class="mb-5 text-center text-sm text-gray-600">
        Enter the password to view this page.
      </p>
      <input
        id="pricing-gate-input"
        type="password"
        autocomplete="off"
        autofocus
        placeholder="Password"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-gray-900 placeholder-gray-400 transition focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
      />
      <p id="pricing-gate-error" hidden class="mt-2 text-sm text-red-600">
        Incorrect password.
      </p>
      <button
        type="submit"
        class="mt-4 w-full rounded-full bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
      >
        Continue
      </button>
    </form>
  </div>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p
          class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary-800"
          data-animate="fade-up"
        >
          Pricing
        </p>
        <h1
          class="text-4xl font-extrabold leading-tight tracking-tight text-gray-900 sm:text-5xl"
          data-animate="fade-up"
        >
          Packages designed to fit your business
        </h1>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-600"
          data-animate="fade-up"
        >
          Transparent pricing built for nail salons, small shops, and LLCs.
          Each tier shows the typical monthly bundle with the exact formula —
          then dial in your numbers with the calculator below.
        </p>
      </div>
    </section>

    <!-- Tier cards -->
    <section id="pricing" class="pb-24" aria-label="Pricing tiers">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 md:grid-cols-3" data-stagger>
          {tierCards.map((t) => <TierCard {...t} />)}
        </div>
      </div>
    </section>

    <!-- One-time services (tax returns + LLC formation) -->
    <OneTimeServicesSection />

    <!-- Calculator placeholder (phases 03-05 fill this) -->
    <section
      id="calculator"
      class="bg-gray-50 py-24"
      aria-label="Pricing calculator"
    >
      <div class="mx-auto max-w-5xl px-6">
        <SectionHeading
          eyebrow="Calculator"
          title="Calculate Your Exact Price"
          subtitle="Enter your business details and we'll compute monthly + one-time setup instantly."
        />
        <div id="calculator-root" class="mt-12" data-animate="fade-up">
          <CalculatorSection />
        </div>
      </div>
    </section>

  </main>

  <script>
    import "@/scripts/pricing-calculator";
  </script>

  <script is:inline>
    (function () {
      const form = document.getElementById("pricing-gate-form");
      if (!form) return;
      const input = document.getElementById("pricing-gate-input");
      const err = document.getElementById("pricing-gate-error");
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        if (!input || !err) return;
        if (input.value === "1233") {
          try { sessionStorage.setItem("ellaPricingAuth", "1"); } catch (_e) { /* ignore */ }
          document.documentElement.setAttribute("data-pricing-auth", "ok");
        } else {
          err.hidden = false;
          input.value = "";
          input.focus();
        }
      });
    })();
  </script>
</BaseLayout>
