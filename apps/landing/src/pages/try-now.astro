---
/**
 * Backward-compatible redirect for older CTA links.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";

const redirectHref = "/get-started/";
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Get Started With Ella Tax Services"
    description="Start tax resolution, audit protection, compliance, filing, or consultation support from Ella Tax Services."
    canonicalUrl="https://ella.tax/get-started/"
    noindex
  />
  <meta slot="head" http-equiv="refresh" content={`0; url=${redirectHref}`} />
  <main class="service-section pt-32 pb-20 sm:pt-36 sm:pb-24">
    <section class="mx-auto max-w-xl px-5 text-center sm:px-6">
      <div class="service-card px-6 py-8 sm:px-8 sm:py-10">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800">
          Redirecting
        </p>
        <h1 class="mt-4 font-heading text-3xl font-bold tracking-tight text-slate-950">
          Taking you to Get Started
        </h1>
        <p class="mt-4 text-base leading-7 text-slate-600">
          If your browser does not redirect automatically, use the button below.
        </p>
        <a class="btn-primary mt-7" href={redirectHref}>
          Continue to online registration
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-500">
        This page is kept for older Ella Tax Services links.
      </p>
    </section>
  </main>
</BaseLayout>
