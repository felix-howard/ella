---
import AdvisorCard from "@/components/advisor-card.astro";
import ContactBand from "@/components/contact-band.astro";
import FAQSection from "@/components/faq-section.astro";
import PageHero from "@/components/page-hero.astro";
import ServiceCard from "@/components/service-card.astro";
import ServiceProcess from "@/components/service-process.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import SoftwareShowcase from "@/components/software-showcase.astro";
import {
  faqSchema,
  organizationSchema,
  professionalServiceSchema,
  websiteSchema,
} from "@/components/seo/structured-data";
import TrustStrip from "@/components/trust-strip.astro";
import {
  homeAdvisors,
  homeAudienceSegments,
  homeFaqs,
  homeProcessSteps,
  homeServiceHighlights,
  homeTrustItems,
} from "@/config/home-page-content";
import { siteConfig } from "@/config/site";
import BaseLayout from "@/layouts/base-layout.astro";

const structuredData = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema(),
  faqSchema(homeFaqs),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Online Tax Filing and Business Tax Support"
    description="Ella Tax Services helps individuals, families, and small businesses file taxes online with advisor support, secure document handling, bookkeeping, notice help, and advisory."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="Online Tax Services"
      title="Online tax filing and business tax support from Ella Tax Services"
      subtitle="File taxes, organize records, handle notices, and plan ahead with a Houston-based team and a secure online process for individuals and businesses."
      primaryCta={{ label: "Start Online Filing", href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: "Book a Consultation", href: siteConfig.cta.secondaryHref }}
    />

    <TrustStrip items={homeTrustItems} />

    <SoftwareShowcase />

    <section class="bg-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-animate="fade-up">
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">
            Services
          </p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            Tax services for the work behind the return
          </h2>
          <p class="mt-4 text-base leading-7 text-slate-600">
            Ella supports the filing, bookkeeping, notice, compliance, and advisory needs that often happen together.
          </p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4" data-stagger>
          {homeServiceHighlights.map((service) => (
            <ServiceCard
              title={service.title}
              description={service.description}
              bullets={service.bullets}
              ctaLabel="Start this service"
            />
          ))}
        </div>
      </div>
    </section>

    <ServiceProcess
      title="A clear online tax process from intake to follow-up"
      steps={homeProcessSteps}
    />

    <section class="section-dark py-16 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:px-8">
        <div data-animate="fade-up">
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-200">
            Who we serve
          </p>
          <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl font-heading">
            Built for real tax situations and convenient online filing
          </h2>
          <p class="mt-4 text-base leading-7 text-primary-50/80">
            Ella works with clients who want online convenience plus a person reviewing the tax facts.
          </p>
        </div>
        <div class="grid gap-3" data-stagger>
          {homeAudienceSegments.map((segment, index) => (
            <div class="rounded-lg border border-white/10 bg-white/[0.06] p-5" data-animate="fade-up">
              <div class="flex items-start gap-4">
                <span class="flex h-8 w-8 flex-none items-center justify-center rounded-full bg-primary-400/15 text-sm font-bold text-primary-100">
                  {index + 1}
                </span>
                <p class="text-sm leading-6 text-white/[0.86]">{segment}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-animate="fade-up">
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">
            Advisor support
          </p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            A team helps keep the next step clear
          </h2>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2" data-stagger>
          {homeAdvisors.map((advisor) => (
            <AdvisorCard name={advisor.name} role={advisor.role} bio={advisor.bio} />
          ))}
        </div>
      </div>
    </section>

    <FAQSection items={homeFaqs} />

    <ContactBand
      title="Start online with Ella Tax Services"
      description={`Start online, book a consultation, or call ${siteConfig.contact.phone} for individual tax, business tax, bookkeeping, notices, or advisory support.`}
    />
  </main>
</BaseLayout>
