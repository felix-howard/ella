---
import { deliverables, processSteps } from "@/config/tax-advisory-presentation";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div data-animate="fade-up">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800 sm:text-sm">
          Planning flow
        </p>
        <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight text-gray-950 sm:text-4xl">
          A process built to close the gap between advice and action.
        </h2>
        <p class="mt-5 text-base leading-7 text-gray-600">
          The engagement turns a slide deck of strategy ideas into an ordered
          client workflow: analyze, agree, implement, review, and file.
        </p>
        <div class="mt-8 rounded-lg border border-primary-100 bg-primary-50 p-5">
          <h3 class="font-heading text-lg font-bold text-primary-950">
            Client deliverables
          </h3>
          <ul class="mt-4 grid gap-3">
            {deliverables.map((item) => (
              <li class="flex gap-3 text-sm font-medium text-primary-950">
                <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent-500" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        {processSteps.map((step, index) => (
          <article
            class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-primary-200 hover:shadow-lg motion-safe:hover:-translate-y-1"
            data-animate="fade-up"
          >
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-primary-700">
              {String(index + 1).padStart(2, "0")} / {step.label}
            </p>
            <h3 class="mt-3 font-heading text-xl font-bold text-gray-950">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
