---
/**
 * Public service pricing page for Ella Tax Services.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import PageHero from "@/components/page-hero.astro";
import FAQSection from "@/components/faq-section.astro";
import ContactBand from "@/components/contact-band.astro";
import { breadcrumbSchema, faqSchema, professionalServiceSchema } from "@/components/seo/structured-data";
import { complianceServices, pricingPackages } from "@/config/pricing-page-content";
import { pricingFaqItems } from "@/config/pricing-faq";
import { siteConfig } from "@/config/site";
import { checkPath } from "@/lib/icons";

const structuredData = [
  professionalServiceSchema(),
  faqSchema(pricingFaqItems),
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Pricing", url: `${siteConfig.url}/pricing` },
  ]),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Tax Service Pricing | Ella Tax Services"
    description="Starting prices and quote guidance for individual tax preparation, business returns, bookkeeping, cleanup, advisory, and compliance support."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="Pricing"
      title="Clear starting points for online tax service."
      subtitle="Ella Tax Services publishes practical starting prices for common work. Final quotes depend on your filing facts, records, states, deadlines, and advisory needs."
      primaryCta={{ label: "Request a Quote", href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: siteConfig.contact.phone, href: siteConfig.contact.phoneHref }}
      align="center"
    />

    <section class="bg-white py-16 sm:py-24" aria-label="Tax service pricing packages">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">Service packages</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            Pricing depends on scope, but the first conversation should not be a mystery.
          </h2>
          <p class="mt-4 text-base leading-7 text-slate-600">
            Use these starting points to decide what to ask about. Ella confirms final pricing
            before work begins and never uses this page as a substitute for engagement terms.
          </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-stagger>
          {pricingPackages.map((item) => (
            <article
              class:list={[
                "service-card flex h-full flex-col p-6",
                item.featured ? "border-accent-200 shadow-orange-700/10" : "",
              ]}
              data-animate="fade-up"
            >
              {item.featured && (
                <p class="mb-3 inline-flex w-fit rounded-full bg-accent-50 px-3 py-1 text-xs font-semibold text-accent-800">
                  Common business path
                </p>
              )}
              <h3 class="text-xl font-semibold text-slate-950 font-heading">{item.title}</h3>
              <p class="mt-3 text-2xl font-bold text-primary-800">{item.price}</p>
              <p class="mt-4 flex-1 text-sm leading-6 text-slate-600">{item.description}</p>
              <ul class="mt-5 space-y-3">
                {item.bullets.map((bullet) => (
                  <li class="flex gap-3 text-sm text-slate-700">
                    <svg class="mt-0.5 h-4 w-4 flex-none text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d={checkPath} />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
              <a
                href={siteConfig.cta.primaryHref}
                class="focus-ring mt-6 inline-flex min-h-11 items-center justify-center rounded-full bg-primary-700 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-primary-800"
              >
                Ask About This Service
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-section py-16 sm:py-24" aria-label="Additional compliance services">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">Compliance and advisory</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            Some tax work needs a scoped quote.
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-600">
            Multi-entity work, cleanup, notices, and state compliance can change quickly based on
            facts. Ella reviews the situation first, then confirms the service path and fee.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {complianceServices.map((service) => (
            <div class="service-card flex items-center gap-3 p-5">
              <svg class="h-5 w-5 flex-none text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={checkPath} />
              </svg>
              <span class="text-sm font-semibold text-slate-800">{service}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-12">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
        <p class="text-sm leading-6 text-slate-600">
          Pricing shown is informational, not a guarantee or tax advice. Engagement terms,
          deliverables, payment timing, and refund rules are confirmed in writing before work begins.
        </p>
      </div>
    </section>

    <FAQSection title="Pricing questions" items={pricingFaqItems} />
    <ContactBand title="Need a quote for your situation?" description="Start with a short inquiry. Ella Tax Services will confirm the scope before requesting sensitive tax documents." />
  </main>
</BaseLayout>
