// ============================================
// MODELS
// ============================================

model Staff {
  id                String    @id @default(cuid())
  clerkId           String?   @unique // Clerk user ID for auth sync
  email             String    @unique
  name              String
  role              StaffRole @default(STAFF)
  avatarUrl         String?
  phoneNumber       String? // E.164 format (+84901234567)
  isActive          Boolean   @default(true)
  isContractorAgent Boolean   @default(false)

  // Notification preferences
  notifyOnUpload              Boolean @default(true) // Enable/disable SMS on client uploads
  notifyOnChat                Boolean @default(false) // Enable/disable SMS when monitored staff sends messages
  notifyOnAgreementSigned     Boolean @default(false) // ADMIN-only: SMS when a client signs an agreement
  notifyOnClientPayment       Boolean @default(false) // ADMIN-only: SMS when a client completes a payment
  notifyOnPaymentFailed       Boolean @default(false) // ADMIN-only: SMS when a recurring quote charge fails
  autoSendUploadLink          Boolean @default(false) // Per-staff auto-send upload link on personal form
  defaultUploadLinkTemplateId String? // Default SMS template for personal form auto-send

  // Audit fields
  deactivatedAt DateTime?
  lastLoginAt   DateTime?

  // NDA signing identity
  title              String? // e.g. "Managing Partner, CPA"
  signaturePngKey    String? // R2 key: staff-signatures/{staffId}/{nonce}.png
  signatureUpdatedAt DateTime?

  actions               Action[]        @relation("AssignedStaff")
  addedChecklistItems   ChecklistItem[] @relation("AddedChecklistItems")
  skippedChecklistItems ChecklistItem[] @relation("SkippedChecklistItems")
  auditLogs             AuditLog[]
  language              Language        @default(EN)
  formSlug              String? // URL slug for public intake form (/form/:orgSlug/:staffSlug)
  presence              StaffPresence?

  organizationId       String?
  organization         Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  managedClients       Client[]            @relation("ManagedClients")
  managedClientLinks   ClientManager[]
  createdClients       Client[]            @relation("CreatedClients")
  updatedClients       Client[]            @relation("UpdatedClients")
  documentViews        DocumentView[]
  uploadedDraftReturns ShareableDocument[]
  sentMessages         Message[]           @relation("SentMessages")

  // Notification subscriptions (admin subscribes to other staff's client uploads)
  notificationSubscriptions NotificationSubscription[] @relation("NotificationSubscriber")
  notificationSubscribers   NotificationSubscription[] @relation("NotificationTarget")

  termsAcceptances               TermsAcceptance[]
  contractorAgreementAcceptances ContractorAgreementAcceptance[]
  staffFiles                     StaffFile[]                     @relation("StaffFiles")
  uploadedStaffFiles             StaffFile[]                     @relation("UploadedStaffFiles")
  reviewedStaffFiles             StaffFile[]                     @relation("ReviewedStaffFiles")
  deletedStaffFiles              StaffFile[]                     @relation("DeletedStaffFiles")
  paymentInfos                   StaffPaymentInfo[]              @relation("StaffPaymentInfos")
  updatedPaymentInfos            StaffPaymentInfo[]              @relation("UpdatedStaffPaymentInfos")
  sentSmsLogs                    SmsSendLog[]                    @relation("SentSmsLogs")
  createdCampaigns               Campaign[]                      @relation("CreatedCampaigns")
  agreementsCreated              Agreement[]                     @relation("AgreementCreatedBy")
  agreementTemplatesCreated      AgreementTemplate[]             @relation("AgreementTemplateCreatedBy")
  createdPaymentQuotes           PaymentQuote[]                  @relation("PaymentQuoteCreatedBy")
  sentQuotes                     PaymentQuote[]                  @relation("QuoteSentBy")
  createdPaymentTemplates        PaymentTemplate[]               @relation("PaymentTemplateCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, formSlug])
  @@unique([id, organizationId])
  @@index([clerkId])
  @@index([organizationId])
}

model StaffFile {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffId           String
  staff             Staff        @relation("StaffFiles", fields: [staffId, organizationId], references: [id, organizationId], onDelete: Cascade)
  uploadedByStaffId String
  uploadedBy        Staff        @relation("UploadedStaffFiles", fields: [uploadedByStaffId, organizationId], references: [id, organizationId], onDelete: Restrict)

  kind             StaffFileKind
  title            String
  category         String?
  originalFilename String
  mimeType         String
  fileSize         Int
  r2Key            String @unique
  checksumSha256   String?

  invoiceYear   Int?
  invoiceMonth  Int?
  invoiceStatus StaffInvoiceStatus?
  replacedById  String?
  replacedBy    StaffFile?          @relation("StaffFileReplacement", fields: [replacedById, organizationId], references: [id, organizationId], onDelete: NoAction)
  replaces      StaffFile[]         @relation("StaffFileReplacement")
  isActive      Boolean             @default(true)

  reviewedByStaffId String?
  reviewedBy        Staff?    @relation("ReviewedStaffFiles", fields: [reviewedByStaffId, organizationId], references: [id, organizationId], onDelete: NoAction)
  reviewedAt        DateTime?
  paidAt            DateTime?
  adminNote         String?   @db.Text
  deletedAt         DateTime?
  deletedByStaffId  String?
  deletedBy         Staff?    @relation("DeletedStaffFiles", fields: [deletedByStaffId, organizationId], references: [id, organizationId], onDelete: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId, staffId, kind])
  @@index([organizationId, kind, invoiceYear, invoiceMonth])
}

model StaffPaymentInfo {
  id                     String              @id @default(cuid())
  organizationId         String
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffId                String
  staff                  Staff               @relation("StaffPaymentInfos", fields: [staffId, organizationId], references: [id, organizationId], onDelete: Cascade)
  country                StaffPaymentCountry
  nameOnAccount          String
  bankName               String
  accountNumberEncrypted String
  accountNumberLast4     String
  routingNumberEncrypted String?
  routingNumberLast4     String?
  updatedByStaffId       String?
  updatedBy              Staff?              @relation("UpdatedStaffPaymentInfos", fields: [updatedByStaffId], references: [id], onDelete: SetNull)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([staffId, country])
  @@unique([id, organizationId])
  @@index([organizationId, staffId])
}

// Staff presence tracking for inbound call routing
model StaffPresence {
  id        String   @id @default(cuid())
  staffId   String   @unique
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  isOnline  Boolean  @default(false)
  deviceId  String? // Twilio device identity: staff_{staffId}
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isOnline])
}

// Staff Terms & Conditions acceptance tracking
model TermsAcceptance {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  version   String // e.g., "2026.03.27"
  signedAt  DateTime @default(now())
  pdfR2Key  String // R2 key: terms/{orgId}/{staffId}/{version}.pdf
  ipAddress String? // IPv4 or IPv6
  userAgent String?  @db.Text

  createdAt DateTime @default(now())

  @@unique([staffId, version])
  @@index([staffId])
  @@index([version])
}

// Independent Contractor agreement acceptance tracking for staff marked as Contractor Agent
model ContractorAgreementAcceptance {
  id                  String       @id @default(cuid())
  staffId             String
  staff               Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version             String
  signedAt            DateTime     @default(now())
  signedPdfR2Key      String
  sourceTemplateR2Key String?
  pdfSha256           String
  signerName          String
  signerEmail         String
  signerIpAddress     String?
  signerUserAgent     String?      @db.Text
  firmSignerName      String
  firmSignerEmail     String
  firmSignerTitle     String?
  firmSignaturePngKey String?
  createdAt           DateTime     @default(now())

  @@unique([staffId, version])
  @@index([staffId])
  @@index([organizationId])
  @@index([version])
}

// Tracks which staff's client uploads an admin subscribes to for SMS notifications
model NotificationSubscription {
  id            String           @id @default(cuid())
  subscriberId  String // The staff who wants to receive notifications
  targetStaffId String // The staff whose clients trigger notifications
  type          SubscriptionType @default(UPLOAD)

  subscriber  Staff @relation("NotificationSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  targetStaff Staff @relation("NotificationTarget", fields: [targetStaffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([subscriberId, targetStaffId, type])
  @@index([subscriberId])
  @@index([targetStaffId])
}

model Organization {
  id         String  @id @default(cuid())
  clerkOrgId String  @unique
  name       String
  slug       String? @unique
  logoUrl    String?
  isActive   Boolean @default(true)

  registrationHeaderMode RegistrationHeaderMode @default(DEFAULT)
  registrationTitle      String?                @db.VarChar(120)
  registrationSubtitle   String?                @db.VarChar(240)

  smsLanguage                  Language @default(VI)
  missedCallTextBack           Boolean  @default(false)
  autoSendFormClientUploadLink Boolean  @default(false)
  defaultUploadLinkTemplateId  String? // Default SMS template for generic form auto-send

  // Firm address + governing law (for NDA header)
  address         String? // Street address
  city            String?
  state           String? // 2-letter code, e.g. "TX"
  zip             String?
  governingState  String? // e.g. "Texas"
  governingCounty String? // e.g. "Harris County"
  firmPhone       String?
  firmEmail       String?
  firmWebsite     String?

  staff                          Staff[]
  staffFiles                     StaffFile[]
  staffPaymentInfos              StaffPaymentInfo[]
  clients                        Client[]
  clientManagers                 ClientManager[]
  clientGroups                   ClientGroup[]
  leads                          Lead[]
  paymentQuotes                  PaymentQuote[]
  paymentTemplates               PaymentTemplate[]
  coupons                        Coupon[]
  payments                       Payment[]
  smsSendLogs                    SmsSendLog[]
  campaigns                      Campaign[]
  agreements                     Agreement[]
  agreementTemplates             AgreementTemplate[]
  contractorAgreementAcceptances ContractorAgreementAcceptance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkOrgId])
}

model ClientGroup {
  id             String        @id @default(cuid())
  name           String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clients        Client[]
  magicLinks     MagicLink[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Client {
  id        String       @id @default(cuid())
  firstName String       @default("")
  lastName  String?
  name      String       @default("") // Computed field for backward compat - will be populated by API
  phone     String
  email     String?
  language  Language     @default(VI)
  source    ClientSource @default(MANUAL)
  tags      String[]     @default([])

  clientType    ClientType   @default(INDIVIDUAL)
  clientGroupId String?
  clientGroup   ClientGroup? @relation(fields: [clientGroupId], references: [id], onDelete: SetNull)

  // Business-specific fields (only for clientType = BUSINESS)
  businessType    BusinessType?
  einEncrypted    String? // AES-256-GCM encrypted EIN
  businessAddress String?
  businessCity    String?
  businessState   String? // 2-char state code
  businessZip     String?

  // Client overview profile fields
  avatarUrl      String? // R2 storage URL for profile picture
  notes          String?   @db.Text // Rich text notes (HTML from Tiptap)
  notesUpdatedAt DateTime? // Track when notes last edited

  profile        ClientProfile?
  engagements    TaxEngagement[]
  taxCases       TaxCase[]
  convertedLeads Lead[]          @relation("ConvertedLead")
  agreements     Agreement[]
  paymentQuotes  PaymentQuote[]
  payments       Payment[]

  // Business-type client relations (for clientType = BUSINESS)
  contractors   Contractor[]
  filingBatches FilingBatch[]
  intakeTokens  ContractorIntakeToken[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  managedById String?
  managedBy   Staff?  @relation("ManagedClients", fields: [managedById], references: [id], onDelete: SetNull)
  managers    ClientManager[]

  createdById String?
  createdBy   Staff?  @relation("CreatedClients", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   Staff?  @relation("UpdatedClients", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([name])
  @@index([source])
  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([managedById])
  @@index([createdById])
  @@index([updatedById])
  @@index([tags], type: Gin)
  @@index([clientType])
  @@index([clientGroupId])
}

model ClientManager {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation(fields: [staffId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([clientId, staffId])
  @@index([staffId])
  @@index([clientId])
  @@index([organizationId, staffId])
}

/// @deprecated Use TaxEngagement for year-specific profile data.
/// Will be removed after all clients migrate to engagement-based queries.
/// Target removal: 2026-Q3 (2 release cycles after migration)
model ClientProfile {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  filingStatus      String?
  hasW2             Boolean @default(false)
  hasBankAccount    Boolean @default(false)
  hasInvestments    Boolean @default(false)
  hasKidsUnder17    Boolean @default(false)
  numKidsUnder17    Int     @default(0)
  paysDaycare       Boolean @default(false)
  hasKids17to24     Boolean @default(false)
  hasSelfEmployment Boolean @default(false)
  hasRentalProperty Boolean @default(false)

  businessName   String?
  ein            String?
  hasEmployees   Boolean @default(false)
  hasContractors Boolean @default(false)
  has1099K       Boolean @default(false)

  // Dynamic intake answers - flexible JSON storage for intake questionnaire responses
  // Maps questionKey -> value (boolean, number, string) from IntakeQuestion model
  intakeAnswers Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TaxEngagement: Year-specific client profile for multi-year support
// Links Client (permanent) -> TaxEngagement (per-year) -> TaxCase (per-form)
model TaxEngagement {
  id       String           @id @default(cuid())
  clientId String
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  taxYear  Int
  status   EngagementStatus @default(DRAFT)

  // Profile fields (copied from ClientProfile for year-specific storage)
  filingStatus      String?
  hasW2             Boolean @default(false)
  hasBankAccount    Boolean @default(false)
  hasInvestments    Boolean @default(false)
  hasKidsUnder17    Boolean @default(false)
  numKidsUnder17    Int     @default(0)
  paysDaycare       Boolean @default(false)
  hasKids17to24     Boolean @default(false)
  hasSelfEmployment Boolean @default(false)
  hasRentalProperty Boolean @default(false)
  businessName      String?
  ein               String?
  hasEmployees      Boolean @default(false)
  hasContractors    Boolean @default(false)
  has1099K          Boolean @default(false)
  intakeAnswers     Json    @default("{}")

  // Relations
  taxCases TaxCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, taxYear])
  @@index([clientId])
  @@index([taxYear])
  @@index([status])
  @@index([clientId, status]) // Filter client's engagements by status
}

model TaxCase {
  id String @id @default(cuid())

  // BACKWARD COMPAT: Keep clientId/taxYear for gradual migration (deprecate in Phase 5+)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Required engagement link (Phase 3: made non-nullable)
  engagementId String
  engagement   TaxEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  taxYear  Int
  taxTypes TaxType[]
  status   TaxCaseStatus @default(INTAKE)

  rawImages        RawImage[]
  digitalDocs      DigitalDoc[]
  checklistItems   ChecklistItem[]
  conversation     Conversation?
  magicLinks       MagicLink[]
  actions          Action[]
  imageGroups      ImageGroup[]
  documentGroups   DocumentGroup[]
  scheduleCExpense ScheduleCExpense?
  scheduleEExpense ScheduleEExpense?
  draftReturns     ShareableDocument[]

  lastContactAt    DateTime?
  entryCompletedAt DateTime?
  filedAt          DateTime?

  // Manual status flags (REVIEW/FILED are manual transitions)
  isInReview Boolean @default(false)
  isFiled    Boolean @default(false)

  // Activity tracking for sorting & stale detection
  lastActivityAt DateTime @default(now())

  // Batch document grouping job tracking
  // When non-null, indicates a grouping job is in progress
  groupingJobId     String?
  groupingStartedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, taxYear])
  @@index([status])
  @@index([taxYear])
  @@index([status, taxYear]) // H1: Composite index for filtering by status and year
  @@index([clientId, status]) // H1: Composite index for client's cases by status
  @@index([lastActivityAt])
  @@index([isInReview])
  @@index([isFiled])
  @@index([engagementId])
  @@index([engagementId, status]) // Filter engagement's cases by status
  @@index([engagementId, lastActivityAt]) // Sort engagement's cases by activity
  @@index([groupingJobId]) // Query cases with active grouping jobs
}

model RawImage {
  id      String  @id @default(cuid())
  caseId  String
  taxCase TaxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  r2Key    String  @unique
  r2Url    String?
  filename String
  mimeType String
  fileSize Int

  status         RawImageStatus @default(UPLOADED)
  classifiedType DocType?
  category       DocCategory? // AI-assigned document category
  displayName    String?        @db.VarChar(255) // Sanitized filename for display (naming convention)
  aiConfidence   Float?
  blurScore      Float?

  // Duplicate detection fields
  imageHash     String? // Perceptual hash (pHash) for duplicate detection
  imageGroupId  String?
  imageGroup    ImageGroup? @relation(fields: [imageGroupId], references: [id])
  duplicateOfId String? // ID of original image this duplicates (for UI badge/link)

  // AI metadata for fallback rename and multi-page detection (Phase 2+3)
  // { fallbackRename: boolean, documentTitle: string, pageInfo: {...}, reasoning: string }
  aiMetadata Json?

  // Multi-page document grouping (Phase 3)
  documentGroupId String?
  documentGroup   DocumentGroup? @relation(fields: [documentGroupId], references: [id])
  pageNumber      Int? // Page within group (1, 2, 3...)
  totalPages      Int? // Total pages in group (known or estimated)
  groupConfidence Float? // AI confidence in grouping (0-1)

  // Entity routing fields (AI auto-routes docs to correct entity in ClientGroup)
  entityConfidence Float? // AI confidence in entity detection (0-1)
  routedFromCaseId String? // Original caseId before entity re-routing (audit only, no FK)

  // Re-upload request tracking
  reuploadRequested   Boolean   @default(false)
  reuploadRequestedAt DateTime?
  reuploadReason      String?
  reuploadFields      Json? // ["ssn", "wages"] - specific unreadable fields

  checklistItemId String?
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id])
  digitalDoc      DigitalDoc?
  documentViews   DocumentView[]

  uploadedVia  MessageChannel @default(PORTAL)
  uploadSource UploadSource   @default(PORTAL_AI) // Routing source: PORTAL_EXPLICIT (owner picked), PORTAL_AI (AI inferred), CPA_MANUAL

  // Viewer display settings (persisted rotation for correct document orientation)
  rotation Int @default(0) // 0, 90, 180, 270 degrees clockwise

  // Retention policy for sensitive identity documents.
  retentionPolicy       String?
  retentionDeleteAt     DateTime?
  retentionDeletedAt    DateTime?
  retentionDeleteReason String?
  storageDeletedAt      DateTime?
  isStorageDeleted      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([category]) // Filter by document category
  @@index([imageGroupId])
  @@index([caseId, classifiedType]) // For duplicate detection queries
  @@index([reuploadRequested])
  @@index([caseId, reuploadRequested])
  @@index([documentGroupId]) // Multi-page grouping lookup
  @@index([routedFromCaseId]) // Entity routing audit trail lookups
  @@index([caseId, documentGroupId]) // Find pages in same group
  @@index([aiMetadata]) // AI metadata queries
  @@index([uploadSource]) // Filter by upload routing source
  @@index([retentionDeleteAt])
  @@index([retentionDeletedAt])
  @@index([category, retentionDeleteAt])
  @@index([isStorageDeleted])
}

// Groups duplicate images of the same physical document
model ImageGroup {
  id      String  @id @default(cuid())
  caseId  String
  taxCase TaxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  docType     DocType
  bestImageId String? // Selected best image from group

  images RawImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([caseId, docType])
}

// Groups multi-page document uploads (Phase 3)
// Tracks related pages uploaded separately (e.g., 3-page form uploaded as 3 images)
model DocumentGroup {
  id     String  @id @default(cuid())
  caseId String
  case   TaxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  baseName     String // Base filename without _PartXofY
  documentType String? // Identified document type (or from fallback)
  pageCount    Int     @default(1)
  confidence   Float // AI confidence in grouping

  images RawImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([caseId, createdAt]) // Recent groups in case
}

model DigitalDoc {
  id         String   @id @default(cuid())
  caseId     String
  taxCase    TaxCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  rawImageId String   @unique
  rawImage   RawImage @relation(fields: [rawImageId], references: [id], onDelete: Cascade)

  docType DocType
  status  DigitalDocStatus @default(PENDING)

  extractedData Json
  aiConfidence  Float?

  verifiedAt   DateTime?
  verifiedById String?

  // Field-level verification tracking
  fieldVerifications Json? // {"ssn": "verified", "wages": "edited", "address": "unreadable"}

  // Copy tracking for data entry
  copiedFields     Json? // {"ssn": true, "wages": false}
  entryCompleted   Boolean   @default(false)
  entryCompletedAt DateTime?

  checklistItemId String?
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([docType])
  @@index([status])
  @@index([entryCompleted])
  @@index([caseId, entryCompleted])
}

model ChecklistTemplate {
  id      String  @id @default(cuid())
  taxType TaxType
  docType DocType

  labelVi       String
  labelEn       String
  descriptionVi String?
  descriptionEn String?
  hintVi        String? // Help text shown to clients
  hintEn        String?

  isRequired    Boolean @default(true)
  condition     String? // JSON: {"questionKey": value} - only show if profile matches
  sortOrder     Int     @default(0)
  category      String
  expectedCount Int     @default(1) // How many documents expected (e.g., 12 for bank statements)

  // Optional link to document library for extended metadata
  docTypeLibraryId String?
  docTypeLibrary   DocTypeLibrary? @relation(fields: [docTypeLibraryId], references: [id])

  checklistItems ChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taxType, docType])
  @@index([taxType])
  @@index([category])
}

model ChecklistItem {
  id         String            @id @default(cuid())
  caseId     String
  taxCase    TaxCase           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id])

  status ChecklistItemStatus @default(MISSING)

  expectedCount Int @default(1)
  receivedCount Int @default(0)

  rawImages   RawImage[]
  digitalDocs DigitalDoc[]

  notes String?

  // Staff override fields
  isManuallyAdded Boolean   @default(false)
  addedById       String?
  addedBy         Staff?    @relation("AddedChecklistItems", fields: [addedById], references: [id])
  addedReason     String?
  skippedAt       DateTime?
  skippedById     String?
  skippedBy       Staff?    @relation("SkippedChecklistItems", fields: [skippedById], references: [id])
  skippedReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([caseId, templateId])
  @@index([caseId])
  @@index([status])
  @@index([caseId, status]) // H1: Composite index for case's checklist by status
}

model Conversation {
  id      String  @id @default(cuid())
  caseId  String  @unique
  taxCase TaxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  messages Message[]

  lastMessageAt DateTime?
  unreadCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastMessageAt, createdAt]) // Composite index for inbox sorting with secondary sort
}

model Message {
  id             String        @id @default(cuid())
  // Polymorphic owner: exactly one of conversationId / leadId is non-null (enforced via DB CHECK).
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel   MessageChannel
  direction MessageDirection
  content   String           @db.VarChar(5000) // M3: Limit message length for security
  reactions Json             @default("[]") // SMS Tapback reactions displayed on the original message

  twilioSid    String? @unique
  twilioStatus String?

  attachmentUrls   String[]
  attachmentR2Keys String[] // Permanent R2 keys for refreshing expired URLs

  isSystem     Boolean @default(false)
  templateUsed String?

  // Staff who sent this message (null for inbound/system messages)
  sentById String?
  sentBy   Staff?  @relation("SentMessages", fields: [sentById], references: [id], onDelete: SetNull)

  // Voice call specific fields (null for non-CALL messages)
  callSid           String? // Twilio Call SID
  recordingUrl      String? // Twilio recording URL (.mp3)
  recordingDuration Int? // Recording duration in seconds
  callStatus        String? // completed, no-answer, busy, failed, canceled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([leadId, createdAt])
  @@index([createdAt])
  @@index([callSid])
  @@index([sentById])
}

model MagicLink {
  id      String   @id @default(cuid())
  caseId  String?
  taxCase TaxCase? @relation(fields: [caseId], references: [id], onDelete: Cascade)

  token String         @unique @default(cuid())
  type  MagicLinkType  @default(PORTAL) // PORTAL for docs, SCHEDULE_C for expense form
  scope MagicLinkScope @default(CASE) // CASE = single TaxCase (legacy), GROUP = ClientGroup entity picker

  // Group-scoped tokens point at a ClientGroup instead of one TaxCase
  clientGroupId String?
  clientGroup   ClientGroup? @relation(fields: [clientGroupId], references: [id], onDelete: SetNull)

  // Optional reference for DRAFT_RETURN type
  draftReturnId String?
  draftReturn   ShareableDocument? @relation(fields: [draftReturnId], references: [id], onDelete: SetNull)

  lastUsedAt DateTime?
  usageCount Int       @default(0)

  expiresAt DateTime?
  isActive  Boolean   @default(true)

  revokedAt    DateTime?
  revokedById  String?
  extendedAt   DateTime?
  extendedById String?
  replacedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([caseId])
  @@index([caseId, isActive, createdAt]) // Phase 02: Composite index for request-reupload queries
  @@index([type]) // Filter by link type
  @@index([caseId, type, isActive]) // Phase 02: Composite index for Schedule C queries
  @@index([draftReturnId]) // Draft return lookup
  @@index([clientGroupId]) // Group-scoped token lookup (Phase 02)
  @@index([revokedAt])
  @@index([replacedById])
}

model Action {
  id      String  @id @default(cuid())
  caseId  String
  taxCase TaxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type     ActionType
  priority ActionPriority @default(NORMAL)

  assignedToId String?
  assignedTo   Staff?  @relation("AssignedStaff", fields: [assignedToId], references: [id])

  isCompleted Boolean   @default(false)
  completedAt DateTime?

  title       String
  description String?
  metadata    Json?

  scheduledFor DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([type])
  @@index([priority])
  @@index([isCompleted])
  @@index([assignedToId])
  @@index([isCompleted, priority]) // Composite index for action queue
  @@index([assignedToId, isCompleted]) // Composite index for staff's pending actions
}

// ============================================
// DYNAMIC CHECKLIST CONFIGURATION
// ============================================

// Intake questions - Dynamic questionnaire for client intake
model IntakeQuestion {
  id          String    @id @default(cuid())
  taxTypes    TaxType[] // Which tax types this question applies to
  questionKey String    @unique // e.g., "hasW2", "hasRentalProperty"

  labelVi String
  labelEn String
  hintVi  String?
  hintEn  String?

  fieldType FieldType // BOOLEAN, SELECT, NUMBER, TEXT
  options   String? // JSON for SELECT type options
  condition String? // JSON: show if other answer matches {"questionKey": "value"}
  section   String // Section grouping: tax_info, income, dependents, business, deductions, foreign
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// Comprehensive document type library for staff document recognition
model DocTypeLibrary {
  id   String @id @default(cuid())
  code String @unique // Internal code matching DocType enum or custom

  labelVi       String
  labelEn       String
  descriptionVi String?
  descriptionEn String?

  category String // personal, income, deductions, business, health, foreign, other
  aliases  String[] // Alternative names for AI matching
  keywords String[] // Keywords for search/classification

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  // Link to checklist templates that use this doc type
  checklistTemplates ChecklistTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============================================
// MESSAGE TEMPLATES
// ============================================

// Message templates for quick client communication
model MessageTemplate {
  id           String                  @id @default(cuid())
  category     MessageTemplateCategory
  title        String // Short title for list display
  content      String                  @db.VarChar(2000) // Template content with placeholders
  placeholders String[] // e.g., ["clientName", "docType"]
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============================================
// AUDIT LOGGING
// ============================================

// Entity types that can be audited
enum AuditEntityType {
  CLIENT
  CLIENT_PROFILE
  TAX_CASE
  TAX_ENGAGEMENT
  ORGANIZATION
  SCHEDULE_C
  BUSINESS
}

// Magic link types for different form flows
enum MagicLinkType {
  PORTAL // Existing document upload
  SCHEDULE_C // Self-employed expense collection form
  SCHEDULE_E // Rental property expense collection form
  DRAFT_RETURN // Draft tax return PDF viewing
}

// Magic link scope: CASE = single TaxCase (legacy), GROUP = entity picker for whole ClientGroup
enum MagicLinkScope {
  CASE
  GROUP
}

enum AgreementType {
  NDA
  ENGAGEMENT_LETTER
  SERVICE_AGREEMENT
  CUSTOM
}

enum AgreementStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  VOIDED
}

enum DepositStatus {
  PENDING
  PAID
  REFUNDED
  FORFEITED
}

enum ScheduleCStatus {
  DRAFT // Client editing
  SUBMITTED // Client submitted, CPA can review
  LOCKED // CPA locked, no more edits
}

enum ScheduleEStatus {
  DRAFT // Client editing
  SUBMITTED // Client submitted, CPA can review
  LOCKED // CPA locked, no more edits
}

enum DocumentStatus {
  ACTIVE // Current version, link valid
  REVOKED // Link manually revoked
  EXPIRED // Link expired
  SUPERSEDED // Replaced by newer version
}

enum ActivityActorType {
  STAFF
  CLIENT_PORTAL
  SYSTEM
}

enum ActivityRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model ActivityLog {
  id             String            @id @default(cuid())
  organizationId String?
  clientId       String?
  caseId         String?
  rawImageId     String?
  magicLinkId    String?
  category       String?
  targetType     String?
  targetId       String?
  targetLabel    String?
  summary        String?           @db.Text
  actorType      ActivityActorType
  actorStaffId   String?
  action         String
  riskLevel      ActivityRiskLevel @default(LOW)
  metadata       Json?
  ipAddress      String?
  userAgent      String?           @db.Text
  route          String?
  method         String?
  createdAt      DateTime          @default(now())

  @@index([organizationId, createdAt])
  @@index([clientId, createdAt])
  @@index([caseId, createdAt])
  @@index([rawImageId, createdAt])
  @@index([actorStaffId, createdAt])
  @@index([magicLinkId, createdAt])
  @@index([action, createdAt])
  @@index([organizationId, category, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorStaffId, category, createdAt])
}

// Audit log for tracking field-level changes
model AuditLog {
  id          String          @id @default(cuid())
  entityType  AuditEntityType
  entityId    String // clientId, profileId, or caseId
  field       String // Field name that was changed
  oldValue    Json? // Previous value (null for new fields)
  newValue    Json? // New value (null for deleted fields)
  changedById String? // Staff who made the change
  changedBy   Staff?          @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([changedById])
  @@index([createdAt])
}

// ============================================
// SCHEDULE C EXPENSE COLLECTION
// ============================================

// Schedule C (Form 1040) expense data for self-employed clients
// Stores income, 20+ IRS Part II expense categories, vehicle info
// One Schedule C per TaxCase (multi-business out of scope)
model ScheduleCExpense {
  id        String  @id @default(cuid())
  taxCaseId String  @unique
  taxCase   TaxCase @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)

  status ScheduleCStatus @default(DRAFT)

  // === Business Information ===
  businessName String? @db.VarChar(200) // Principal business or profession
  businessDesc String? @db.VarChar(500) // Business description / product or service

  // === Income Section (Part I) ===
  // All monetary fields use Decimal(12,2) for precision up to $999,999,999.99
  grossReceipts Decimal? @db.Decimal(12, 2) // Line 1: Gross receipts or sales
  returns       Decimal? @db.Decimal(12, 2) // Line 2: Returns and allowances
  costOfGoods   Decimal? @db.Decimal(12, 2) // Line 4: Cost of goods sold (Part III total)
  otherIncome   Decimal? @db.Decimal(12, 2) // Line 6: Other income

  // === Expenses (Part II) - IRS Schedule C Line 8-27 ===
  // Note: carExpense (Line 9) and vehicleMiles are mutually exclusive - use one method only
  advertising        Decimal? @db.Decimal(12, 2) // Line 8
  carExpense         Decimal? @db.Decimal(12, 2) // Line 9: Actual car/truck expenses (OR use mileage)
  commissions        Decimal? @db.Decimal(12, 2) // Line 10
  contractLabor      Decimal? @db.Decimal(12, 2) // Line 11
  depletion          Decimal? @db.Decimal(12, 2) // Line 12
  depreciation       Decimal? @db.Decimal(12, 2) // Line 13: Depreciation and Sec 179
  employeeBenefits   Decimal? @db.Decimal(12, 2) // Line 14
  insurance          Decimal? @db.Decimal(12, 2) // Line 15: Insurance (other than health)
  interestMortgage   Decimal? @db.Decimal(12, 2) // Line 16a
  interestOther      Decimal? @db.Decimal(12, 2) // Line 16b
  legalServices      Decimal? @db.Decimal(12, 2) // Line 17
  officeExpense      Decimal? @db.Decimal(12, 2) // Line 18
  pensionPlans       Decimal? @db.Decimal(12, 2) // Line 19
  rentEquipment      Decimal? @db.Decimal(12, 2) // Line 20a
  rentProperty       Decimal? @db.Decimal(12, 2) // Line 20b
  repairs            Decimal? @db.Decimal(12, 2) // Line 21
  supplies           Decimal? @db.Decimal(12, 2) // Line 22
  taxesAndLicenses   Decimal? @db.Decimal(12, 2) // Line 23
  travel             Decimal? @db.Decimal(12, 2) // Line 24a
  meals              Decimal? @db.Decimal(12, 2) // Line 24b: Deductible meals (50%)
  utilities          Decimal? @db.Decimal(12, 2) // Line 25
  wages              Decimal? @db.Decimal(12, 2) // Line 26
  otherExpenses      Decimal? @db.Decimal(12, 2) // Line 27a
  otherExpensesNotes String?  @db.VarChar(1000) // Line 27a description

  // === Custom Expenses (dynamic "Other" list) ===
  customExpenses Json? @default("[]") // [{name: string, amount: number}]

  // === Vehicle Information (Part IV) ===
  vehicleMiles            Int? // Total business miles driven
  vehicleCommuteMiles     Int? // Commuting miles (not deductible)
  vehicleOtherMiles       Int? // Other personal miles
  vehicleDateInService    DateTime? // Date vehicle placed in service
  vehicleUsedForCommute   Boolean   @default(false)
  vehicleAnotherAvailable Boolean   @default(false) // Another vehicle for personal use
  vehicleEvidenceWritten  Boolean   @default(false) // Written evidence to support deduction

  // === Version Tracking ===
  // versionHistory JSON structure:
  // [{ version: number, data: {...expense fields}, submittedAt: string, changes: string[] }]
  version        Int  @default(1)
  versionHistory Json @default("[]")

  // === Timestamps ===
  submittedAt DateTime? // When client submitted (status -> SUBMITTED)
  lockedAt    DateTime? // When CPA locked (status -> LOCKED)
  lockedById  String? // Staff who locked
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([taxCaseId, status])
}

// ============================================
// SCHEDULE E RENTAL PROPERTY EXPENSE COLLECTION
// ============================================

// Schedule E (Form 1040) rental property data for clients with rental income
// Stores up to 3 properties as JSON array with income and expense data
// One ScheduleEExpense per TaxCase (all properties in single record)
model ScheduleEExpense {
  id        String  @id @default(cuid())
  taxCaseId String  @unique
  taxCase   TaxCase @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)

  status ScheduleEStatus @default(DRAFT)

  // === Properties stored as JSON array (A, B, C, D, ... unlimited) ===
  // Each property: { id, address, propertyType, monthsRented, fairRentalDays,
  //   personalUseDays, rentsReceived, expenses (7 fields), otherExpenses[], totals }
  properties Json @default("[]")

  // === Version Tracking ===
  // versionHistory JSON structure:
  // [{ version: number, properties: [...], submittedAt: string, changes: string[] }]
  version        Int  @default(1)
  versionHistory Json @default("[]")

  // === Timestamps ===
  submittedAt DateTime? // When client submitted (status -> SUBMITTED)
  lockedAt    DateTime? // When CPA locked (status -> LOCKED)
  lockedById  String? // Staff who locked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([taxCaseId, status])
  @@index([lockedById])
}

// ============================================
// DRAFT RETURN SHARING
// ============================================

// Shareable document sharing - CPAs upload PDFs (draft returns, tax analyses, etc.) for client review via portal
// Table name preserved as `draft_returns` via @@map to avoid data movement during rename
model ShareableDocument {
  id        String  @id @default(cuid())
  taxCaseId String
  taxCase   TaxCase @relation(fields: [taxCaseId], references: [id], onDelete: Cascade)

  // Display title shown to client (e.g. "Draft Return", "Tax Analysis")
  title String @default("Draft Return")

  // PDF storage
  r2Key    String @unique // cases/{caseId}/draft-returns/{timestamp}.pdf
  filename String // Original filename for display
  fileSize Int // Bytes

  // Versioning
  version Int @default(1)

  // Uploader
  uploadedById String
  uploadedBy   Staff  @relation(fields: [uploadedById], references: [id])

  // Status
  status DocumentStatus @default(ACTIVE)

  // View tracking
  viewCount    Int       @default(0)
  lastViewedAt DateTime?

  // Soft delete — set when CPA removes the section
  deletedAt DateTime?

  // Magic link for portal access
  magicLinks MagicLink[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taxCaseId])
  @@index([taxCaseId, status, deletedAt])
  @@index([status])
  @@map("DraftReturn")
}

// ============================================
// DOCUMENT VIEW TRACKING
// ============================================

// Tracks which documents each staff member has viewed
// Used for per-CPA "new upload" badge calculations
model DocumentView {
  id         String   @id @default(cuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  rawImageId String
  rawImage   RawImage @relation(fields: [rawImageId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())

  @@unique([staffId, rawImageId])
  @@index([staffId])
  @@index([rawImageId])
}

// ============================================
// LEAD / MARKETING
// ============================================

model Lead {
  id                   String     @id @default(cuid())
  firstName            String
  lastName             String
  phone                String
  email                String?
  businessName         String?
  status               LeadStatus @default(NEW)
  campaignTag          String?    @map("source") // renamed from source; e.g., "free-tax-meeting-march-2026" from eventSlug
  tags                 String[]   @default([])
  notes                String?    @db.Text
  smsConsentAccepted   Boolean    @default(false)
  smsConsentAcceptedAt DateTime?
  smsConsentText       String?    @db.Text

  // Conversion tracking
  convertedToId String?
  convertedTo   Client?   @relation("ConvertedLead", fields: [convertedToId], references: [id], onDelete: SetNull)
  convertedAt   DateTime?

  // Organization scope
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  smsSendLogs   SmsSendLog[]
  agreements    Agreement[]
  messages      Message[]
  paymentQuotes PaymentQuote[]
  payments      Payment[]

  // Staff-side "last read" marker for inbound SMS unread count
  messagesLastReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@index([phone])
  @@index([tags], type: Gin)
}

model PaymentQuote {
  id                String                  @id @default(cuid())
  organizationId    String?
  organization      Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clientId          String?
  client            Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId            String?
  lead              Lead?                   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerEmail     String?
  customerName      String?
  businessName      String?
  inputSnapshot     Json
  resultSnapshot    Json
  monthlyTotalCents Int // recurring total, cadence in billingInterval (month or year)
  setupTotalCents   Int // one-time total
  // Link source + billing cadence for the custom-link feature.
  // source defaults to "calculator" so existing rows/flows are untouched.
  source              String   @default("calculator") // "calculator" | "custom"
  billingInterval     String? // null=one-time | "month" | "year"
  appliedCouponId     String? // owner-attached, pre-applied coupon
  appliedCoupon       Coupon?  @relation(fields: [appliedCouponId], references: [id], onDelete: SetNull)
  allowPromotionCodes Boolean  @default(false) // client may type a code at Stripe checkout
  status            String                  @default("pending_checkout")
  lastStripeEventId String?
  lastStripeEventAt DateTime?
  createdByStaffId  String?
  createdByStaff    Staff?                  @relation("PaymentQuoteCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  // Sendable-quote fields: portal pay token, send timestamp ("is sendable" marker), and SMS sender attribution
  payToken          String?                 @unique // portal token; null for anonymous quotes from the create-link panel
  sentAt            DateTime? // set when the quote is sent to a client/lead
  sentByStaffId     String?
  sentByStaff       Staff?                  @relation("QuoteSentBy", fields: [sentByStaffId], references: [id], onDelete: SetNull)
  checkoutSessions  StripeCheckoutSession[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([organizationId, createdAt])
  @@index([clientId])
  @@index([leadId])
  @@index([createdByStaffId])
  @@index([sentByStaffId])
  @@index([status])
  @@index([lastStripeEventAt])
  @@index([appliedCouponId])
}

// App-side source of truth for a discount, mirroring a Stripe Coupon + Promotion Code.
// Stripe owns the discount math (percent/amount/duration/redeem_by/max_redemptions);
// this model backs the management UI and the quote-attach flow.
model Coupon {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code                  String // promotion code shown to client, e.g. "WELCOME10"
  name                  String? // internal label
  discountType          String // "percent" | "amount"
  percentOff            Int? // 1..100 when percent
  amountOffCents        Int? // > 0 when amount (currency = org default)
  currency              String       @default("usd")
  duration              String       @default("once") // "once" | "forever" | "repeating"
  durationInMonths      Int? // when duration = "repeating"
  maxRedemptions        Int? // usage limit (null = unlimited)
  redeemBy              DateTime? // expiry
  stripeCouponId        String? // synced Stripe Coupon id
  stripePromotionCodeId String? // synced Stripe Promotion Code id
  active                Boolean      @default(true) // soft "disable" toggle
  timesRedeemed         Int          @default(0) // cached from Stripe for display
  createdByStaffId      String?
  appliedQuotes         PaymentQuote[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId, active])
}

model PaymentTemplate {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String       @db.VarChar(120)
  description      String?      @db.VarChar(500)
  items            Json
  createdByStaffId String?
  createdByStaff   Staff?       @relation("PaymentTemplateCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  archivedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId, archivedAt, updatedAt])
  @@index([organizationId, name])
}

model StripeCheckoutSession {
  id                    String       @id @default(cuid())
  paymentQuoteId        String
  paymentQuote          PaymentQuote @relation(fields: [paymentQuoteId], references: [id], onDelete: Cascade)
  stripeSessionId       String       @unique
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  stripePaymentIntentId String?
  status                String
  lastStripeEventId     String?
  lastStripeEventAt     DateTime?
  url                   String?      @db.Text
  expiresAt             DateTime?
  paidAt                DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([paymentQuoteId])
  @@index([status])
  @@index([lastStripeEventAt])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([stripePaymentIntentId])
}

enum PaymentType {
  DEPOSIT
  BALANCE
  OTHER
  RECURRING
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

// Deposit/balance payments collected from clients or leads (e.g. after agreement signing).
// Distinct from PaymentQuote (pricing-calculator checkouts) — keep names separate.
model Payment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agreementId    String?
  agreement      Agreement?   @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  type     PaymentType   @default(DEPOSIT)
  status   PaymentStatus @default(PENDING)
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("usd")

  // Public pay-link token (portal/pay/:payToken). Separate lifecycle from agreement signing token.
  payToken              String  @unique
  stripeSessionId       String?
  stripePaymentIntentId String?

  paidAt      DateTime?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([leadId])
  @@index([agreementId])
  @@index([organizationId, status])
}

model SmsSendLog {
  id        String        @id @default(cuid())
  message   String        @db.Text
  status    SmsSendStatus
  twilioSid String?
  error     String?

  // Relations
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sentById       String
  sentBy         Staff        @relation("SentSmsLogs", fields: [sentById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sentAt DateTime @default(now())

  @@index([leadId])
  @@index([organizationId])
  @@index([sentById])
  @@index([twilioSid])
}

model Agreement {
  id String @id @default(cuid())

  // Type + display
  type         AgreementType @default(NDA)
  title        String        @db.VarChar(200)
  internalNote String?       @db.Text

  // Tenancy
  // leadId is nullable + SetNull so agreements are preserved (linked to clientId) when a converted Lead is deleted.
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Template snapshot
  templateId        String?
  template          AgreementTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateVersion   String
  customContentHtml String?            @db.Text // Sanitized HTML snapshot per-lead. NULL = render from templateVersion.
  // R2 key of a staff-uploaded source PDF. When set, the agreement body is the
  // uploaded PDF (used as-is); signing appends a generated signature page rather
  // than rendering from customContentHtml/templateVersion.
  uploadedPdfKey    String?

  // Status
  status            AgreementStatus @default(DRAFT)
  depositStatus     DepositStatus?
  depositAmount     Decimal?        @db.Decimal(10, 2)
  depositPaidAt     DateTime?
  depositResolvedAt DateTime?
  depositNote       String?         @db.Text

  // Public access token (replaces MagicLink for NDA)
  token      String    @unique
  expiresAt  DateTime?
  /**
   * Validity window in days from send/rotation. Persisted so resend reuses
   * the originally-chosen duration and Extend can also default to it.
   */
  expiryDays Int       @default(30)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  usageCount Int       @default(0)

  // Signing snapshot (PII — never emit to general application logs)
  signedAt        DateTime?
  signerName      String? // PII
  signerEmail     String? // PII
  signerIpAddress String? // PII
  signerUserAgent String?   @db.Text // PII
  signaturePngKey String?
  signedPdfKey    String?

  // Firm signing snapshot (snapshotted at agreement create time — Pattern B)
  firmSignerName      String?
  firmSignerTitle     String?
  firmSignerEmail     String?
  firmSignaturePngKey String? // copied from Staff.signaturePngKey at send time
  firmSignedAt        DateTime?

  // Client signer metadata. Rep name is business-only; title is required for all client signatures.
  clientAuthRepName  String?
  clientAuthRepTitle String?

  // Audit
  createdByUserId String
  createdBy       Staff  @relation("AgreementCreatedBy", fields: [createdByUserId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([clientId])
  @@index([organizationId])
  @@index([token])
  @@index([status])
  @@index([leadId, status])
  @@index([organizationId, type])
  @@index([templateId])
}

model AgreementTemplate {
  id   String        @id @default(cuid())
  type AgreementType
  name String        @db.VarChar(200)

  contentHtml          String   @db.Text
  defaultDepositAmount Decimal? @db.Decimal(10, 2)
  isArchived           Boolean  @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdByUserId String
  createdBy       Staff  @relation("AgreementTemplateCreatedBy", fields: [createdByUserId], references: [id])

  agreements Agreement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, type, isArchived])
}

model Campaign {
  id               String         @id @default(cuid())
  name             String
  slug             String
  tag              String
  status           CampaignStatus @default(ACTIVE)
  description      String?        @db.Text
  formIntroContent String?        @db.Text
  formHeaderMode   RegistrationHeaderMode @default(DEFAULT)
  formTitle        String?                @db.VarChar(120)
  formSubtitle     String?                @db.VarChar(240)

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      Staff        @relation("CreatedCampaigns", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, organizationId])
  @@unique([tag, organizationId])
  @@index([organizationId, status])
}

// ============================================
// 1099-NEC: Contractor for business clients
// ============================================

model Contractor {
  id           String  @id @default(cuid())
  clientId     String
  client       Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  tinType      String  @default("SSN") // "SSN" or "EIN"
  ssnEncrypted String // AES-256-GCM encrypted SSN/EIN
  ssnLast4     String // Last 4 digits for masked display
  address      String
  city         String
  state        String
  zip          String
  email        String?
  phone        String?

  forms Form1099NEC[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ============================================
// Contractor Intake Token (public intake form)
// ============================================

model ContractorIntakeToken {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token    String  @unique @default(cuid())
  taxYear  Int
  isActive Boolean @default(true)

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([token])
  @@index([clientId, isActive])
}

// ============================================
// 1099-NEC: Form and Filing
// ============================================

enum Form1099Status {
  DRAFT
  VALIDATED
  IMPORTED
  PDF_READY
  SUBMITTED
  ACCEPTED
  REJECTED
}

model Form1099NEC {
  id                     String         @id @default(cuid())
  contractorId           String
  contractor             Contractor     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  batchId                String?
  batch                  FilingBatch?   @relation(fields: [batchId], references: [id])
  taxYear                Int
  amountBox1             Decimal        @db.Decimal(12, 2)
  amountBox4             Decimal        @default(0) @db.Decimal(12, 2)
  pdfStorageKey          String?
  copyBStorageKey        String?
  copyCStorageKey        String?
  status                 Form1099Status @default(DRAFT)
  taxbanditsRecordId     String?
  taxbanditsSubmissionId String?
  validationErrors       String[]       @default([])
  efileSubmittedAt       DateTime?
  efileStatus            String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([contractorId, taxYear])
  @@index([batchId])
  @@index([status])
  @@index([taxbanditsRecordId])
  @@index([taxbanditsSubmissionId])
}

enum FilingStatus {
  PENDING
  SUBMITTED
  PROCESSING
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
}

model FilingBatch {
  id                     String        @id @default(cuid())
  clientId               String
  client                 Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  taxYear                Int
  status                 FilingStatus  @default(PENDING)
  taxbanditsSubmissionId String?
  submittedAt            DateTime?
  acceptedAt             DateTime?
  rejectedAt             DateTime?
  rejectionReason        String?
  totalForms             Int           @default(0)
  acceptedForms          Int           @default(0)
  rejectedForms          Int           @default(0)
  tinCheckEnabled        Boolean       @default(true)
  uspsEnabled            Boolean       @default(true)
  eDeliveryEnabled       Boolean       @default(true)
  forms                  Form1099NEC[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([taxbanditsSubmissionId])
}
