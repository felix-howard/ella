---
import { advisoryFlow, processSteps } from "@/config/tax-advisory-presentation";

const toneClasses = {
  blue: "border-blue-300 bg-blue-50 text-blue-950",
  green: "border-emerald-300 bg-emerald-50 text-emerald-950",
  purple: "border-violet-300 bg-violet-50 text-violet-950",
  orange: "border-amber-300 bg-amber-50 text-amber-950",
  lime: "border-lime-300 bg-lime-50 text-lime-950",
};

type FlowNode = (typeof advisoryFlow)[number];
type Tone = keyof typeof toneClasses;

const byId = Object.fromEntries(advisoryFlow.map((item) => [item.id, item])) as Record<
  string,
  FlowNode
>;
const getNode = (id: string) => byId[id];
const getToneClass = (tone: string) => toneClasses[tone as Tone];
---

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="mx-auto max-w-3xl text-center" data-animate="fade-up">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800">
        Client path
      </p>
      <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
        From initial consultation to e-file and tax planning.
      </h2>
    </div>

    <div class="mt-10 rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-8" data-animate="fade-up">
      <div class="mx-auto grid max-w-5xl gap-3 text-center text-sm font-semibold sm:text-base">
        <div class:list={["mx-auto w-full max-w-sm rounded-lg border p-4", getToneClass(getNode("initial").tone)]}>
          {getNode("initial").label}
        </div>
        <div class="grid gap-3 md:grid-cols-[1fr_auto_1fr] md:items-center">
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("nda").tone)]}>
            <p>{getNode("nda").label}</p>
            <p class="text-sm font-medium opacity-80">{getNode("nda").sublabel}</p>
          </div>
          <span class="hidden text-slate-400 md:block">or</span>
          <div class="rounded-lg border border-slate-300 bg-stone-100 p-4 text-stone-700">
            Not the right service fit
          </div>
        </div>
        <div class="text-slate-400" aria-hidden="true">&darr;</div>
        <div class="grid gap-3 md:grid-cols-[1fr_auto_1fr] md:items-center">
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("analysis").tone)]}>
            {getNode("analysis").label}
          </div>
          <span class="hidden text-slate-400 md:block">&rarr;</span>
          <div class="rounded-lg border border-slate-300 bg-stone-100 p-4 text-stone-700">
            Not the right service fit
          </div>
        </div>
        {["proposal", "engagement", "onboard", "bookkeeping"].map((id) => (
          <>
            <div class="text-slate-400" aria-hidden="true">&darr;</div>
            <div class:list={["mx-auto w-full max-w-sm rounded-lg border p-4", getToneClass(getNode(id).tone)]}>
              <p>{getNode(id).label}</p>
              {getNode(id).sublabel && <p class="text-sm font-medium opacity-80">{getNode(id).sublabel}</p>}
            </div>
          </>
        ))}
        <div class="text-slate-400" aria-hidden="true">&darr;</div>
        <div class="grid gap-3 md:grid-cols-[1fr_auto_1fr] md:items-center">
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("records").tone)]}>
            {getNode("records").label}
          </div>
          <span class="hidden text-slate-400 md:block">&rarr;</span>
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("specialist").tone)]}>
            {getNode("specialist").label}
          </div>
        </div>
        <div class="text-slate-400" aria-hidden="true">&darr;</div>
        <div class:list={["mx-auto w-full max-w-xl rounded-lg border p-4", getToneClass(getNode("zoom").tone)]}>
          <p>{getNode("zoom").label}</p>
          <p class="text-sm font-medium opacity-80">{getNode("zoom").sublabel}</p>
        </div>
        <div class="grid gap-3 md:grid-cols-[1fr_1fr]">
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("sign").tone)]}>
            {getNode("sign").label}
          </div>
          <div class:list={["rounded-lg border p-4", getToneClass(getNode("planning").tone)]}>
            {getNode("planning").label}
          </div>
        </div>
        <div class:list={["mx-auto w-full max-w-xs rounded-lg border p-4", getToneClass(getNode("efile").tone)]}>
          {getNode("efile").label}
        </div>
      </div>
    </div>

    <div class="mt-16 grid gap-5 lg:grid-cols-5" data-stagger>
      {processSteps.map((group) => (
        <article class="rounded-lg border border-slate-300 bg-white p-4 shadow-sm" data-animate="fade-up">
          <h3 class="flex min-h-[68px] items-center justify-center rounded-lg border-2 border-slate-900 bg-slate-100 px-3 text-center font-heading text-lg font-bold uppercase text-slate-950">
            {group.phase}
          </h3>
          <ul class="mt-6 grid gap-5">
            {group.items.map((item) => (
              <li class="flex min-h-[76px] items-center justify-center rounded-none border-2 border-slate-900 bg-orange-50 p-3 text-center text-base font-semibold uppercase leading-tight text-slate-950">
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
