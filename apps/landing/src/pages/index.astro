  <!-- Showcase loop controller: restarts animations on a timer -->
  <script>
    function initShowcaseLoops() {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      document.querySelectorAll<HTMLElement>('.showcase-mockup').forEach((mockup) => {
        const duration = parseInt(mockup.dataset.loopDuration || '5000', 10);
        const fadeTime = 600; // ms for fade-out before restart
        const pauseTime = 800; // ms pause between loops
        let intervalId: number | undefined;

        /** Apply animations from data-sc-anim to inline style */
        function playAnimations() {
          mockup.classList.remove('fading');
          mockup.classList.add('playing');
          mockup.querySelectorAll<HTMLElement>('[data-sc-anim]').forEach((el) => {
            el.style.animation = el.dataset.scAnim || '';
          });
        }

        /** Clear animations and fade out */
        function resetAnimations() {
          mockup.classList.add('fading');
          mockup.classList.remove('playing');
          mockup.querySelectorAll<HTMLElement>('[data-sc-anim]').forEach((el) => {
            el.style.animation = 'none';
          });
        }

        /** Start the loop cycle when mockup enters viewport */
        function startLoop() {
          playAnimations();
          intervalId = window.setInterval(() => {
            // Fade out
            resetAnimations();
            // After fade completes + pause, restart
            setTimeout(() => {
              playAnimations();
            }, fadeTime + pauseTime);
          }, duration);
        }

        // Watch for the .animate class (added by existing IntersectionObserver)
        const observer = new MutationObserver((mutations) => {
          for (const m of mutations) {
            if (m.type === 'attributes' && mockup.classList.contains('animate') && !intervalId) {
              startLoop();
              observer.disconnect();
            }
          }
        });
        observer.observe(mockup, { attributes: true, attributeFilter: ['class'] });

        // If already animated (e.g. reduced motion fallback added .animate synchronously)
        if (mockup.classList.contains('animate')) {
          startLoop();
          observer.disconnect();
        }
      });
    }

    // Run after DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initShowcaseLoops);
    } else {
      initShowcaseLoops();
    }
  </script>
