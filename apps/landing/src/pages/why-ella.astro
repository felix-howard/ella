---
import ContactBand from "@/components/contact-band.astro";
import FAQSection from "@/components/faq-section.astro";
import PageHero from "@/components/page-hero.astro";
import SectionHeading from "@/components/section-heading.astro";
import TrustStrip from "@/components/trust-strip.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import { breadcrumbSchema } from "@/components/seo/structured-data";
import BaseLayout from "@/layouts/base-layout.astro";
import { checkPath, xPath } from "@/lib/icons";
import {
  clientProblems,
  comparisonRows,
  ellaApproach,
  trustItems,
  whyEllaFaq,
} from "@/config/why-ella-data";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "Why Ella", url: `${siteConfig.url}/why-ella` },
  ]),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Why Choose Ella Tax Services - Online Tax Help"
    description="See why individuals, families, and small businesses choose Ella Tax Services for online tax filing, planning, bookkeeping, and advisory support."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="Why Ella Tax Services"
      title="Online tax help for clients who want clarity"
      subtitle="Ella Tax Services combines secure online document sharing with advisor review, practical tax support, and clear next steps for individuals and small businesses."
      primaryCta={{ label: "Start Online Tax Filing", href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: "View Services", href: "/services" }}
    />

    <TrustStrip items={trustItems} />

    <section class="bg-white py-16 sm:py-24" aria-label="Common tax service challenges">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="The challenge" title="Tax help gets stressful when context is missing" />
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-stagger>
          {clientProblems.map((problem) => (
            <article class="service-card p-6" data-animate="fade-up">
              <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-orange-100 text-accent-800">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={problem.icon} />
                </svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-slate-950">{problem.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{problem.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-section py-16 sm:py-24" aria-label="Ella Tax Services approach">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="The Ella approach" title="Advisor-supported filing, planning, and business tax support" />
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-stagger>
          {ellaApproach.map((item) => (
            <article class="service-card p-6" data-animate="fade-up">
              <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-700 text-white">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-slate-950">{item.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24" aria-label="Tax service comparison">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Compare options"
          title="DIY software, local office, or Ella Tax Services"
          subtitle="Different tax situations need different levels of support. Ella is designed for clients who want online convenience plus advisor help."
        />
        <div class="mt-10 overflow-x-auto rounded-lg border border-primary-100 bg-white shadow-sm">
          <table class="min-w-[820px] w-full text-left text-sm">
            <thead class="bg-primary-50 text-slate-950">
              <tr>
                <th scope="col" class="p-4 font-semibold">Need</th>
                <th scope="col" class="p-4 font-semibold">DIY software</th>
                <th scope="col" class="p-4 font-semibold">Traditional office</th>
                <th scope="col" class="p-4 font-semibold">Ella Tax Services</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-primary-100">
              {comparisonRows.map((row) => (
                <tr>
                  <th scope="row" class="p-4 font-semibold text-slate-950">{row.category}</th>
                  <td class="p-4 text-slate-600">
                    <span class="flex gap-2">
                      <svg class="mt-0.5 h-4 w-4 flex-none text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d={xPath} />
                      </svg>
                      {row.diy}
                    </span>
                  </td>
                  <td class="p-4 text-slate-600">{row.local}</td>
                  <td class="p-4 font-medium text-slate-800">
                    <span class="flex gap-2">
                      <svg class="mt-0.5 h-4 w-4 flex-none text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d={checkPath} />
                      </svg>
                      {row.ella}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <FAQSection title="Why clients choose Ella" items={whyEllaFaq} includeSchema={true} />
    <ContactBand title="Get online tax help with a clear next step" />
  </main>
</BaseLayout>
