---
/**
 * Full-width service inquiry CTA with contact form.
 * Used across pages for consistent bottom CTA.
 */
import ContactForm from "@/components/contact-form.astro";

interface Props {
  title: string;
  description?: string;
  idPrefix?: string;
  /** Legacy props kept for backward compatibility but no longer used */
  buttonText?: string;
  buttonHref?: string;
}

const { title, description, idPrefix = "cta-contact" } = Astro.props;
---

<section class="service-section relative overflow-hidden py-16 sm:py-24">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center" data-animate="fade-up">
      <h2 class="text-2xl font-bold text-slate-950 sm:text-3xl md:text-4xl font-heading">
        {title}
      </h2>
      {description && (
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
          {description}
        </p>
      )}
    </div>

    <div class="service-card mx-auto mt-8 max-w-3xl p-6 sm:mt-12 sm:p-8" data-animate="fade-up">
      <ContactForm tone="light" idPrefix={idPrefix} />
    </div>
  </div>
</section>
