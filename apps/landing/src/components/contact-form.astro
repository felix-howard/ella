---
/**
 * Contact/demo request CTA that links to Facebook.
 * Inverted button style (white bg, emerald text) for dark aurora backgrounds.
 */
---

<div class="mx-auto max-w-lg text-center">
  <a
    href="https://www.facebook.com/andy.hayven"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block w-full rounded-full bg-white px-6 py-3 text-sm font-semibold text-primary-600 shadow-sm transition-all hover:bg-gray-50 hover:shadow-lg active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
  >
    Request a Demo
  </a>
  <p class="mt-4 text-sm text-white/70">
    Click to connect with us on Facebook
  </p>
</div>
