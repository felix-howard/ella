---
/**
 * Sticky responsive navbar with scroll-based floating pill animation.
 * Initial: full-width transparent header.
 * On scroll: shrinks into a floating rounded container with light gradient bg.
 * Includes Login link, CTA button, mobile menu, and accessibility features.
 */
import { navLinks } from "@/config/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
// Normalize path: strip trailing slash for consistent comparison (production serves /about/ vs /about)
const normalizedPath = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");
---

<!-- Backdrop overlay for mobile menu -->
<div
  id="mobile-backdrop"
  class="fixed inset-0 z-[45] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
></div>

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out"
  aria-label="Main navigation"
>
  <!-- Outer wrapper for centering the floating pill -->
  <div id="nav-pill" class="nav-pill-initial transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
      <!-- Logo -->
      <a href="/" class="shrink-0 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500">
        <img src="/ella-logo.png" alt="ella.tax" class="h-8 object-contain transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]" />
      </a>

      <!-- Desktop nav links (centered) -->
      <nav class="hidden items-center gap-8 md:flex">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-base font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500",
              normalizedPath === link.href
                ? "text-primary-600"
                : "text-gray-600 hover:text-gray-900",
            ]}
            aria-current={normalizedPath === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: Login + CTA -->
      <div class="flex items-center gap-3 md:gap-5">
        <!-- Login button (desktop) -->
        <a
          href="https://app.ella.tax/"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all hover:bg-primary-700 hover:shadow-lg hover:shadow-primary-600/25 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 md:px-5 md:py-2.5"
        >
          Login
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="flex h-10 w-10 min-h-[44px] min-w-[44px] items-center justify-center rounded-lg text-gray-600 hover:bg-gray-100 active:scale-[0.98] transition-transform focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg
            id="hamburger-icon"
            class="h-6 w-6 transition-all duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile slide-in menu (right to left) -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 bottom-0 z-50 w-72 translate-x-full bg-white shadow-2xl transition-transform duration-300 ease-out md:hidden"
  aria-hidden="true"
>
  <!-- Close button -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
    <span class="text-lg font-semibold text-gray-900">Menu</span>
    <button
      id="mobile-menu-close"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-600 hover:bg-gray-100 active:scale-[0.98] transition-transform focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
      aria-label="Close menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex flex-col gap-1 px-4 py-4">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          "rounded-lg px-4 py-3 text-base font-medium transition-colors active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500",
          normalizedPath === link.href
            ? "bg-primary-50 text-primary-600"
            : "text-gray-600 hover:bg-gray-50 hover:text-gray-900",
        ]}
        aria-current={normalizedPath === link.href ? "page" : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<style>
  /* Initial state: full-width, transparent, no border-radius */
  .nav-pill-initial {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: none;
    border-radius: 0;
    /* Equal horizontal margin keeps expansion symmetric from both sides */
    margin: 0;
    box-shadow: none;
    /* border-radius snaps to 0 instantly so no rounded corners on full-width */
    transition:
      background 500ms cubic-bezier(0.4, 0, 0.2, 1),
      backdrop-filter 500ms cubic-bezier(0.4, 0, 0.2, 1),
      margin 500ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 500ms cubic-bezier(0.4, 0, 0.2, 1),
      border-radius 0ms;
  }

  /* Scrolled state: floating pill with rounded corners and gradient bg (desktop only) */
  @media (min-width: 768px) {
    .nav-pill-scrolled {
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.92),
        rgba(245, 250, 246, 0.95),
        rgba(255, 255, 255, 0.92)
      );
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: none;
      border-radius: 9999px;
      /* Equal left/right margin creates symmetric inset from both edges */
      margin: 0.75rem 8rem;
      box-shadow:
        0 4px 24px rgba(0, 0, 0, 0.06),
        0 1px 3px rgba(0, 0, 0, 0.04),
        0 0 0 1px rgba(255, 255, 255, 0.6) inset;
      /* border-radius animates in with a delay so width shrinks first */
      transition:
        background 500ms cubic-bezier(0.4, 0, 0.2, 1),
        backdrop-filter 500ms cubic-bezier(0.4, 0, 0.2, 1),
        margin 500ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 500ms cubic-bezier(0.4, 0, 0.2, 1),
        border-radius 400ms cubic-bezier(0.4, 0, 0.2, 1) 100ms;
    }

    /* Scrolled: content fills pill edge-to-edge, logo/buttons at edges */
    .nav-pill-scrolled > div {
      max-width: 100%;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    /* Smaller logo in scrolled state */
    .nav-pill-scrolled img {
      height: 1.5rem;
    }
  }
</style>

<script>
  /** Navbar: scroll-based floating pill animation (desktop), mobile slide-in menu */
  const navPill = document.getElementById("nav-pill");
  const btn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-backdrop");

  const SCROLL_THRESHOLD = 50;
  let isOpen = false;
  let isScrolled = false;

  /* ── Scroll-based pill animation (desktop only) ── */
  function updateNavState() {
    if (window.innerWidth < 768) return; // Skip on mobile
    const scrolled = window.scrollY > SCROLL_THRESHOLD;
    if (scrolled === isScrolled) return;
    isScrolled = scrolled;

    if (scrolled) {
      navPill?.classList.remove("nav-pill-initial");
      navPill?.classList.add("nav-pill-scrolled");
    } else {
      navPill?.classList.remove("nav-pill-scrolled");
      navPill?.classList.add("nav-pill-initial");
    }
  }

  window.addEventListener("scroll", updateNavState, { passive: true });
  updateNavState();

  /* ── Mobile menu helpers ── */
  function getFocusableElements(): HTMLElement[] {
    if (!menu) return [];
    return Array.from(
      menu.querySelectorAll<HTMLElement>("a[href], button:not([disabled]), input:not([disabled])")
    );
  }

  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;
    document.body.style.overflow = "";
    menu?.classList.add("translate-x-full");
    menu?.classList.remove("translate-x-0");
    menu?.setAttribute("aria-hidden", "true");
    backdrop?.classList.add("opacity-0", "pointer-events-none");
    backdrop?.classList.remove("opacity-100", "pointer-events-auto");
    btn?.setAttribute("aria-expanded", "false");
  }

  function openMenu() {
    if (isOpen) return;
    isOpen = true;
    document.body.style.overflow = "hidden";
    menu?.classList.remove("translate-x-full");
    menu?.classList.add("translate-x-0");
    menu?.setAttribute("aria-hidden", "false");
    backdrop?.classList.remove("opacity-0", "pointer-events-none");
    backdrop?.classList.add("opacity-100", "pointer-events-auto");
    btn?.setAttribute("aria-expanded", "true");
    menu?.querySelector("a")?.focus();
  }

  function toggleMenu() {
    isOpen ? closeMenu() : openMenu();
  }

  btn?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);

  /* Keyboard: Escape to close, Tab focus trap */
  document.addEventListener("keydown", (e) => {
    if (!isOpen) return;
    if (e.key === "Escape") {
      closeMenu();
      btn?.focus();
      return;
    }
    if (e.key === "Tab") {
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;
      const firstEl = focusable[0];
      const lastEl = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === firstEl) {
          e.preventDefault();
          lastEl.focus();
        }
      } else {
        if (document.activeElement === lastEl) {
          e.preventDefault();
          firstEl.focus();
        }
      }
    }
  });

  /* Close menu on resize to desktop */
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && isOpen) closeMenu();
  }, { passive: true });
</script>
