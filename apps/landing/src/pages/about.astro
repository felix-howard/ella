---
import AdvisorCard from "@/components/advisor-card.astro";
import ContactBand from "@/components/contact-band.astro";
import FAQSection from "@/components/faq-section.astro";
import PageHero from "@/components/page-hero.astro";
import SectionHeading from "@/components/section-heading.astro";
import ServiceCard from "@/components/service-card.astro";
import ServiceProcess from "@/components/service-process.astro";
import TrustStrip from "@/components/trust-strip.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import {
  breadcrumbSchema,
  organizationSchema,
} from "@/components/seo/structured-data";
import BaseLayout from "@/layouts/base-layout.astro";
import {
  aboutFaq,
  advisors,
  companyFacts,
  howWeWorkSteps,
  serviceHighlights,
  values,
} from "@/config/about-data";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "About", url: `${siteConfig.url}/about` },
  ]),
  organizationSchema(),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="About Ella Tax Services LLC - Tax Resolution and Compliance"
    description="Learn about Ella Tax Services LLC, a Houston-based tax services company focused on tax resolution, audit protection, and compliance support."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="About Ella Tax Services"
      title="Advisor-supported help for tax problems, audits, and compliance"
      subtitle="Ella Tax Services LLC helps individuals, families, and small businesses resolve notices, protect records, prepare filings, and manage compliance through a clearer online process."
      primaryCta={{ label: siteConfig.cta.primaryLabel, href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: siteConfig.cta.secondaryLabel, href: siteConfig.cta.secondaryHref }}
    />

    <TrustStrip />

    <section class="bg-white py-16 sm:py-24" aria-label="Company story">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start lg:px-8">
        <div class="max-w-3xl">
          <SectionHeading eyebrow="Our company" title="A clearer way to handle tax risk online" align="left" />
          <div class="mt-6 space-y-5 border-l-2 border-primary-200 pl-6 text-base leading-8 text-slate-600">
            <p>
              Tax clients deserve more than scattered email threads, confusing IRS notices, and last-minute document requests.
              Ella Tax Services brings tax resolution, audit protection, compliance, preparation, and advisory support into
              an organized online service experience.
            </p>
            <p>
              We are Houston-based and digital-first, so clients can start online, share records
              securely, and receive practical guidance from a tax service team focused on clear next steps.
            </p>
          </div>
        </div>
        <div class="grid gap-4">
          {companyFacts.map((fact, index) => (
            <div class:list={[
              "rounded-lg border p-5",
              index === 0
                ? "border-primary-700 bg-surface-dark text-white shadow-xl shadow-primary-900/15"
                : "border-neutral-border bg-white shadow-sm",
            ]}>
              <p class:list={[
                "text-xs font-semibold uppercase tracking-widest",
                index === 0 ? "text-primary-200" : "text-primary-700",
              ]}>{fact.label}</p>
              <p class:list={[
                "mt-2 text-sm font-semibold leading-6",
                index === 0 ? "text-white" : "text-slate-950",
              ]}>{fact.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="service-section py-16 sm:py-24" aria-label="What we do">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="What we do" title="Tax services for resolution, audit readiness, and compliance" />
        <div class="mt-10 grid gap-6 lg:grid-cols-3" data-stagger>
          {serviceHighlights.map((service) => (
            <div data-animate="fade-up">
              <ServiceCard {...service} ctaLabel="Start online" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <ServiceProcess
      eyebrow="How we work"
      title="Digital-first tax support with advisor review"
      steps={howWeWorkSteps}
    />

    <section class="bg-primary-50 py-16 sm:py-24" aria-label="Advisor support">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="Team support" title="Support from people who understand IRS and state tax work" />
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {advisors.map((advisor) => <AdvisorCard {...advisor} />)}
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24" aria-label="Our values">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="Values" title="What shapes our service" />
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {values.map((value) => (
            <article class="service-card p-6" data-animate="fade-up">
              <h3 class="text-lg font-semibold text-slate-950">{value.label}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{value.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <FAQSection title="About Ella Tax Services" items={aboutFaq} includeSchema={true} />
    <ContactBand description="Start tax resolution, ask about audit protection, or contact the team about compliance, bookkeeping, filings, and notices." />
  </main>
</BaseLayout>
