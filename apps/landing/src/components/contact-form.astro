---
/**
 * Demo request form with name, email, and company fields.
 * Styled for dark aurora backgrounds with glassmorphism inputs.
 * On submit, opens Facebook contact page.
 *
 * Props:
 *  - `prefillMessage` — default value for the message textarea (e.g. price breakdown from calculator).
 *  - `idPrefix` — allows multiple instances on one page without DOM id collisions
 *    (e.g. pricing page has both <CTASection> and <ConsultationModal> rendering this form).
 */

interface Props {
  prefillMessage?: string;
  idPrefix?: string;
}

const { prefillMessage = "", idPrefix = "demo" } = Astro.props;
const formId = `${idPrefix}-form`;
const nameId = `${idPrefix}-name`;
const emailId = `${idPrefix}-email`;
const companyId = `${idPrefix}-company`;
const messageId = `${idPrefix}-message`;
---

<form id={formId} class="space-y-5">
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for={nameId} class="mb-1.5 block text-sm font-medium text-white/90">
        Full Name
      </label>
      <input
        type="text"
        id={nameId}
        name="name"
        placeholder="John Smith"
        required
        class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/40 backdrop-blur-sm transition-all duration-200 focus:border-white/30 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20"
      />
    </div>
    <div>
      <label for={emailId} class="mb-1.5 block text-sm font-medium text-white/90">
        Work Email
      </label>
      <input
        type="email"
        id={emailId}
        name="email"
        placeholder="john@yourfirm.com"
        required
        class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/40 backdrop-blur-sm transition-all duration-200 focus:border-white/30 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20"
      />
    </div>
  </div>

  <div>
    <label for={companyId} class="mb-1.5 block text-sm font-medium text-white/90">
      Company / Firm Name
    </label>
    <input
      type="text"
      id={companyId}
      name="company"
      placeholder="Smith & Associates CPA"
      class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/40 backdrop-blur-sm transition-all duration-200 focus:border-white/30 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20"
    />
  </div>

  <div>
    <label for={messageId} class="mb-1.5 block text-sm font-medium text-white/90">
      Message <span class="text-white/40">(optional)</span>
    </label>
    <textarea
      id={messageId}
      name="message"
      rows="3"
      placeholder="Tell us about your firm and what you're looking for..."
      class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/40 backdrop-blur-sm transition-all duration-200 focus:border-white/30 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20"
    >{prefillMessage}</textarea>
  </div>

  <button
    type="submit"
    class="group relative w-full overflow-hidden rounded-full bg-white px-6 py-3.5 text-sm font-semibold text-primary-700 shadow-lg transition-all duration-300 hover:shadow-xl hover:shadow-white/25 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-base"
  >
    <span class="relative z-10 flex items-center justify-center gap-2">
      Request a Demo
      <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </button>

  <p class="text-center text-xs text-white/50">
    We'll reach out within 24 hours to schedule your personalized demo.
  </p>
</form>

<script is:inline define:vars={{ formId }}>
  document.getElementById(formId)?.addEventListener('submit', (e) => {
    e.preventDefault();
    window.open('https://www.facebook.com/my.ella.tax/', '_blank', 'noopener,noreferrer');
  });
</script>
