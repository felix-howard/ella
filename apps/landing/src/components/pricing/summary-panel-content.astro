---
/**
 * Shared inner content for the pricing summary panel — reused by both the
 * desktop sticky aside and the mobile bottom-sheet drawer in
 * `summary-panel.astro`. Duplicating this markup would drift over time, so
 * phase 07 extracts it here. `pricing-calculator-render.ts` updates every
 * `[data-calc-*]` node via `querySelectorAll`, so rendering works for N copies.
 *
 * Worker-range badge, empty / result / enterprise states.
 * Money formatting stays in `pricing-calculator-render.ts` via `textContent`
 * (XSS-safe by construction).
 */
import { siteConfig } from "@/config/site";
import QuotePrintAction from "./quote-print-action.astro";
---

<!-- Worker-range badge — wrapper drives visibility, span holds text -->
<div class="mb-4 flex items-center justify-between">
  <span class="text-sm font-semibold uppercase tracking-wide text-gray-500">
    Your estimate
  </span>
  <span
    data-calc-state="tierBadge"
    hidden
    class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700 ring-1 ring-primary-100"
  >
    <span data-calc-output="tierLabel"></span>
  </span>
</div>

<!-- Empty state (visible by default, hidden once hasAnySelection===true) -->
<div
  data-calc-state="empty"
  class="flex flex-col items-center gap-3 py-8 text-center"
>
  <svg
    class="h-10 w-10 text-gray-300"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M9 17v-2a4 4 0 014-4h4m-4-4V5a2 2 0 10-4 0v2m12 10v-6a2 2 0 00-2-2h-2M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
    />
  </svg>
  <p class="text-sm text-gray-500">
    Fill in the form to see your estimate.
  </p>
</div>

<!-- Result state (hidden initially; phase 05 unhides once has result + not enterprise) -->
<div data-calc-state="result" hidden class="space-y-5">
  <!-- Monthly section -->
  <section aria-label="Monthly cost breakdown">
    <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
      Monthly
    </h4>
    <ul data-calc-output="monthlyItems" class="mt-2 divide-y divide-gray-100"></ul>
    <div class="mt-3 flex items-baseline justify-between border-t border-gray-200 pt-3">
      <span class="text-sm font-medium text-gray-700">Monthly total</span>
      <span class="text-xl font-bold tabular-nums text-gray-900">
        $<span data-calc-output="monthlyTotal">0</span>
        <span class="text-sm font-medium text-gray-500">/mo</span>
      </span>
    </div>
  </section>

  <!-- Yearly pre-pay section -->
  <section data-calc-state="yearlyGroup" hidden aria-label="Yearly pre-pay cost breakdown">
    <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
      Yearly
    </h4>
    <ul data-calc-output="yearlyItems" class="mt-2 divide-y divide-gray-100"></ul>
    <div class="mt-3 flex items-baseline justify-between border-t border-gray-200 pt-3">
      <span class="text-sm font-medium text-gray-700">Yearly pre-pay total</span>
      <span class="text-xl font-bold tabular-nums text-gray-900">
        $<span data-calc-output="yearlyTotal">0</span>
      </span>
    </div>
  </section>

  <!-- Setup section -->
  <section aria-label="One-time setup cost breakdown">
    <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
      One-time setup
    </h4>
    <ul data-calc-output="setupItems" class="mt-2 divide-y divide-gray-100"></ul>
    <div class="mt-3 flex items-baseline justify-between border-t border-gray-200 pt-3">
      <span class="text-sm font-medium text-gray-700">Setup one-time total</span>
      <span class="text-xl font-bold tabular-nums text-gray-900">
        $<span data-calc-output="setupTotal">0</span>
      </span>
    </div>
  </section>

  <!-- Due Today + next-month clarifier -->
  <div class="rounded-xl bg-primary-50 p-4 ring-1 ring-primary-100">
    <div class="flex items-baseline justify-between">
      <span class="text-sm font-semibold text-primary-900">Due Today</span>
      <span class="text-lg font-bold tabular-nums text-primary-900">
        $<span data-calc-output="dueToday">0</span>
      </span>
    </div>
    <div class="mt-2 flex items-baseline justify-between">
      <span class="text-sm font-medium text-primary-900/80">Next month onward</span>
      <span class="text-lg font-bold tabular-nums text-primary-900">
        $<span data-calc-output="nextMonthTotal">0</span>
        <span class="text-sm font-medium text-primary-900/70">/month</span>
      </span>
    </div>
  </div>

  <QuotePrintAction />

  <button class="btn-secondary w-full" type="button" data-calc-consultation-trigger>
    Book a consultation
  </button>
</div>

<!-- Enterprise state (hidden initially; phase 05 unhides when isEnterprise===true) -->
<div
  data-calc-state="enterprise"
  hidden
  role="status"
  aria-live="polite"
  class="rounded-xl bg-primary-50 p-5 ring-1 ring-primary-100"
>
  <p class="text-sm font-semibold text-primary-900">
    Contact us for enterprise pricing
  </p>
  <p class="mt-1 text-sm text-primary-800/80">
    You have 20+ 1099 workers. Let's put together a custom quote tailored
    to your operation.
  </p>
  <p class="mt-3 text-sm text-primary-900">
    Reach us at
    <a
      href={siteConfig.cta.primaryHref}
      class="font-semibold underline underline-offset-2 hover:text-primary-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
    >
      online registration
    </a>
    and we'll follow up within one business day.
  </p>
  <button class="btn-primary mt-5 w-full" type="button" data-calc-consultation-trigger>
    Book a consultation
  </button>
</div>
