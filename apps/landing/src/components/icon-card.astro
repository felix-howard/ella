---
/**
 * Reusable card with icon circle, title, and description.
 * Used on: Why Ella (problems, solutions, differentiators), potentially other pages.
 * Accepts variant prop to control icon circle color scheme.
 */
interface Props {
  icon: string;
  title: string;
  description: string;
  variant?: "primary" | "mint" | "accent" | "error";
}

const { icon, title, description, variant = "primary" } = Astro.props;

const styles = {
  primary: "bg-primary-100 text-primary-700",
  mint: "bg-emerald-100 text-emerald-700",
  accent: "bg-accent-100 text-accent-600",
  error: "bg-error-100 text-error-500",
}[variant];
---

<div class="service-card service-card-interactive p-6">
  <div class:list={["mb-4 flex h-12 w-12 items-center justify-center rounded-lg ring-1 ring-white/60", styles]}>
    <svg
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
    </svg>
  </div>
  <h3 class="text-base font-bold text-slate-950">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
</div>
