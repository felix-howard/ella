---
/**
 * Service-first page hero for Ella Tax Services.
 * Visual image paths should use `/assets/descriptive-kebab-case.{webp,jpg,png}`.
 */
import { siteConfig } from "@/config/site";

interface HeroCta {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryCta?: HeroCta;
  secondaryCta?: HeroCta;
  visualImage?: string;
  visualAlt?: string;
  align?: "center" | "split";
}

const {
  eyebrow = "Ella Tax Services",
  title,
  subtitle,
  primaryCta = { label: siteConfig.cta.primaryLabel, href: siteConfig.cta.primaryHref },
  secondaryCta = { label: siteConfig.cta.secondaryLabel, href: siteConfig.cta.secondaryHref },
  visualImage,
  visualAlt = "Tax documents prepared for online filing",
  align = "split",
} = Astro.props;

const isCenter = align === "center";
---

<section class="service-section relative overflow-hidden border-b border-neutral-border/70 pt-28 sm:pt-32">
  <div
    class:list={[
      "mx-auto grid max-w-7xl gap-10 px-4 pb-12 sm:px-6 sm:pb-16 lg:px-8",
      isCenter ? "text-center" : "lg:grid-cols-[1fr_0.86fr] lg:items-center",
    ]}
  >
    <div class:list={[isCenter ? "mx-auto max-w-4xl" : "max-w-3xl"]} data-animate="fade-up">
      {eyebrow && (
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">
          {eyebrow}
        </p>
      )}
      <h1 class="mt-4 max-w-4xl text-4xl font-extrabold leading-[1.05] text-slate-950 sm:text-5xl lg:text-6xl font-heading">
        {title}
      </h1>
      <p class:list={["mt-6 text-lg leading-8 text-slate-600", isCenter ? "mx-auto max-w-3xl" : "max-w-2xl"]}>
        {subtitle}
      </p>
      <div class:list={["mt-8 flex flex-col gap-3 sm:flex-row", isCenter ? "justify-center" : ""]}>
        <a
          href={primaryCta.href}
          class="btn-primary w-full sm:w-auto"
        >
          {primaryCta.label}
        </a>
        <a
          href={secondaryCta.href}
          class="btn-secondary w-full sm:w-auto"
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>

    {!isCenter && (
      <div class="relative" data-animate="scale-in" data-delay="0.15s">
        {visualImage ? (
          <img
            src={visualImage}
            alt={visualAlt}
            width="640"
            height="520"
            class="aspect-[4/3] w-full rounded-lg border border-white object-cover shadow-2xl shadow-slate-900/15"
            loading="eager"
          />
        ) : (
          <div class="service-card overflow-hidden p-3 sm:p-4">
            <div class="rounded-lg bg-surface-dark p-5 text-white">
              <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
                <p class="text-sm font-semibold text-primary-100">Prepared for your advisor</p>
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">Secure</span>
              </div>
              <div class="mt-5 space-y-4">
                <div class="rounded-lg bg-white p-4 text-slate-800">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-sm font-semibold">Tax document checklist</p>
                      <p class="mt-1 text-xs text-slate-500">Income, deductions, business records, notices</p>
                    </div>
                    <span class="rounded-full bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700">Reviewed</span>
                  </div>
                  <div class="mt-4 space-y-2">
                    <div class="h-2 w-full rounded-full bg-slate-100"></div>
                    <div class="h-2 w-4/5 rounded-full bg-primary-100"></div>
                    <div class="h-2 w-3/5 rounded-full bg-orange-100"></div>
                  </div>
                </div>
                <div class="rounded-lg border border-white/15 bg-white/10 p-4">
                  <p class="text-sm font-semibold">Advisor note</p>
                  <p class="mt-2 text-sm leading-6 text-primary-100">
                    We confirm open items, prepare the next step, and keep filing questions in one place.
                  </p>
                </div>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2 text-center text-xs font-medium text-slate-700 sm:gap-3">
              <div class="rounded-lg bg-primary-50 p-3">Secure upload</div>
              <div class="rounded-lg bg-sky-50 p-3">Advisor review</div>
              <div class="rounded-lg bg-orange-50 p-3">Clear next step</div>
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>
