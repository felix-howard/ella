---
/**
 * Service inquiry page for Ella Tax Services.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import PageHero from "@/components/page-hero.astro";
import TrustStrip from "@/components/trust-strip.astro";
import ServiceProcess from "@/components/service-process.astro";
import FAQSection from "@/components/faq-section.astro";
import ContactBand from "@/components/contact-band.astro";
import ContactForm from "@/components/contact-form.astro";
import { faqSchema, professionalServiceSchema } from "@/components/seo/structured-data";
import { getStartedFaqItems, getStartedProcess, inquiryCards } from "@/config/get-started-page-content";
import { siteConfig } from "@/config/site";
import { checkPath } from "@/lib/icons";

const structuredData = [
  professionalServiceSchema(),
  faqSchema(getStartedFaqItems),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Get Started With Ella Tax Services"
    description="Start online tax filing, bookkeeping, tax notice, or advisory support with Ella Tax Services."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="Get Started"
      title="Start your online tax service request."
      subtitle="Tell Ella Tax Services what you need help with. We will confirm scope, explain next steps, and move sensitive tax information through secure onboarding after engagement."
      primaryCta={{ label: "Send Inquiry", href: "#inquiry-form" }}
      secondaryCta={{ label: siteConfig.contact.phone, href: siteConfig.contact.phoneHref }}
    />

    <TrustStrip />

    <section class="bg-white py-16 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">Safe first contact</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            Share enough to route the request, not sensitive tax data.
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-600">
            This page starts the conversation for individual tax preparation, business returns,
            bookkeeping, cleanup, payroll coordination, notices, and advisory questions.
            Ella will request private documents only through secure onboarding after scope is confirmed.
          </p>
          <address class="mt-6 not-italic text-sm leading-6 text-slate-600">
            <span class="block font-semibold text-slate-950">{siteConfig.legalName}</span>
            <a class="block text-primary-700 underline underline-offset-2" href={siteConfig.contact.phoneHref}>
              {siteConfig.contact.phone}
            </a>
            <a class="block text-primary-700 underline underline-offset-2" href={siteConfig.contact.emailHref}>
              {siteConfig.contact.email}
            </a>
            <span class="block">{siteConfig.contact.address.streetAddress}</span>
            <span class="block">
              {siteConfig.contact.address.addressLocality}, {siteConfig.contact.address.addressRegion} {siteConfig.contact.address.postalCode}
            </span>
          </address>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          {inquiryCards.map((card) => (
            <article class="service-card p-5">
              <h3 class="text-base font-semibold text-slate-950">{card.title}</h3>
              <ul class="mt-4 space-y-3">
                {card.items.map((item) => (
                  <li class="flex gap-2 text-sm leading-5 text-slate-600">
                    <svg class="mt-0.5 h-4 w-4 flex-none text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d={checkPath} />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <ServiceProcess steps={getStartedProcess} />

    <section id="inquiry-form" class="service-section py-16 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-primary-700">Inquiry form</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl font-heading">
            Start with basic contact details.
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-600">
            The form opens a prepared email to Ella Tax Services. You can also call or message
            us on Facebook if that is easier for the first conversation.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-sky-200 bg-white px-5 py-3 text-sm font-semibold text-primary-800 transition-colors hover:bg-sky-50" href={siteConfig.facebook} target="_blank" rel="noopener noreferrer">
              Facebook
            </a>
            <a class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-sky-200 bg-white px-5 py-3 text-sm font-semibold text-primary-800 transition-colors hover:bg-sky-50" href={siteConfig.contact.emailHref}>
              {siteConfig.contact.email}
            </a>
          </div>
        </div>
        <div class="service-card p-6 sm:p-8">
          <ContactForm idPrefix="get-started" tone="light" submitLabel="Send Inquiry" />
        </div>
      </div>
    </section>

    <FAQSection title="Before you start" items={getStartedFaqItems} />
    <ContactBand />
  </main>
</BaseLayout>
