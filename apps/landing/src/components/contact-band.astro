---
import { siteConfig } from "@/config/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Talk with Ella Tax Services",
  description = "Start tax resolution, ask about audit protection, or get compliance help before deadlines move closer.",
} = Astro.props;
const address = siteConfig.contact.address;
---

<section class="section-dark py-14 text-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[1fr_auto] lg:items-center lg:px-8">
    <div>
      <h2 class="text-2xl font-extrabold leading-tight sm:text-3xl font-heading">{title}</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-primary-100/80">{description}</p>
      <address class="mt-5 not-italic text-sm leading-6 text-primary-100/75">
        {address.streetAddress}, {address.addressLocality}, {address.addressRegion} {address.postalCode}
      </address>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
      <a class="btn-primary w-full px-5 sm:w-auto" href={siteConfig.cta.primaryHref}>
        {siteConfig.cta.primaryLabel}
      </a>
      <a class="btn-dark w-full px-5 sm:w-auto" href={siteConfig.cta.secondaryHref}>
        {siteConfig.cta.secondaryLabel}
      </a>
    </div>
  </div>
</section>
