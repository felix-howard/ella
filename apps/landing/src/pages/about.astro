---
import AdvisorCard from "@/components/advisor-card.astro";
import ContactBand from "@/components/contact-band.astro";
import FAQSection from "@/components/faq-section.astro";
import PageHero from "@/components/page-hero.astro";
import SectionHeading from "@/components/section-heading.astro";
import ServiceCard from "@/components/service-card.astro";
import ServiceProcess from "@/components/service-process.astro";
import TrustStrip from "@/components/trust-strip.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import {
  breadcrumbSchema,
  organizationSchema,
} from "@/components/seo/structured-data";
import BaseLayout from "@/layouts/base-layout.astro";
import {
  aboutFaq,
  advisors,
  companyFacts,
  howWeWorkSteps,
  serviceHighlights,
  values,
} from "@/config/about-data";
import { siteConfig } from "@/config/site";

const structuredData = [
  breadcrumbSchema([
    { name: "Home", url: siteConfig.url },
    { name: "About", url: `${siteConfig.url}/about` },
  ]),
  organizationSchema(),
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="About Ella Tax Services LLC - Online Tax Services"
    description="Learn about Ella Tax Services LLC, a Houston-based online tax services company supporting individuals, families, and small businesses."
    structuredData={structuredData}
  />

  <main>
    <PageHero
      eyebrow="About Ella Tax Services"
      title="Online tax service with advisor support"
      subtitle="Ella Tax Services LLC helps individuals, families, and small businesses file taxes online, organize records, plan ahead, and handle tax questions with a clearer process."
      primaryCta={{ label: "Start Online Tax Filing", href: siteConfig.cta.primaryHref }}
      secondaryCta={{ label: siteConfig.cta.secondaryLabel, href: siteConfig.cta.secondaryHref }}
    />

    <TrustStrip />

    <section class="bg-white py-16 sm:py-24" aria-label="Company story">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div>
          <SectionHeading eyebrow="Our company" title="A clearer way to get tax help online" align="left" />
          <div class="mt-6 space-y-4 text-base leading-7 text-slate-600">
            <p>
              Tax clients deserve more than scattered email threads and last-minute document requests.
              Ella Tax Services brings tax preparation, planning, bookkeeping, and advisory support into
              an organized online service experience.
            </p>
            <p>
              We are Houston-based and digital-first, so clients can start online, share records
              securely, and receive practical guidance from a tax service team.
            </p>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {companyFacts.map((fact) => (
            <div class="service-card p-5">
              <p class="text-xs font-semibold uppercase tracking-widest text-primary-700">{fact.label}</p>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-950">{fact.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="service-section py-16 sm:py-24" aria-label="What we do">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="What we do" title="Tax services for real filing and business situations" />
        <div class="mt-10 grid gap-6 lg:grid-cols-3" data-stagger>
          {serviceHighlights.map((service) => (
            <div data-animate="fade-up">
              <ServiceCard {...service} ctaLabel="Start online" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <ServiceProcess
      eyebrow="How we work"
      title="Digital-first, advisor-supported tax service"
      steps={howWeWorkSteps}
    />

    <section class="bg-primary-50 py-16 sm:py-24" aria-label="Advisor support">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="Team support" title="Support from people who understand tax service" />
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {advisors.map((advisor) => <AdvisorCard {...advisor} />)}
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-24" aria-label="Our values">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="Values" title="What shapes our service" />
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {values.map((value) => (
            <article class="service-card p-6" data-animate="fade-up">
              <h3 class="text-lg font-semibold text-slate-950">{value.label}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{value.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <FAQSection title="About Ella Tax Services" items={aboutFaq} includeSchema={true} />
    <ContactBand description="Start online tax filing, ask about advisory, or contact the team about bookkeeping and notices." />
  </main>
</BaseLayout>
