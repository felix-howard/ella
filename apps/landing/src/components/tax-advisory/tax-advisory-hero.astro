---
import { heroMetrics } from "@/config/tax-advisory-presentation";
---

<section class="relative overflow-hidden bg-[linear-gradient(180deg,#f6fbf8_0%,#ffffff_72%,#f8fafc_100%)] pt-28 pb-16 sm:pt-32 lg:pb-20">
  <div class="absolute inset-x-0 top-0 h-px bg-primary-100" aria-hidden="true"></div>
  <div class="mx-auto grid max-w-7xl gap-10 px-5 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
    <div>
      <p
        class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800 sm:text-sm"
        data-animate="fade-up"
      >
        Tax advisory engagement
      </p>
      <h1
        class="mt-5 max-w-4xl font-heading text-4xl font-extrabold leading-tight tracking-tight text-gray-950 sm:text-5xl xl:text-[4rem]"
        data-animate="fade-up"
        data-delay="0.08s"
      >
        Make smarter tax decisions with a year-round advisory plan.
      </h1>
      <p
        class="mt-6 max-w-2xl text-base leading-8 text-gray-700 sm:text-lg"
        data-animate="fade-up"
        data-delay="0.16s"
      >
        Ella turns strategy consultation, document onboarding, tax return
        analysis, implementation tasks, estimates, and filing into one client
        experience.
      </p>
      <div
        class="mt-8 flex flex-col gap-3 sm:flex-row"
        data-animate="fade-up"
        data-delay="0.24s"
      >
        <a
          href="https://www.facebook.com/my.ella.tax/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] cursor-pointer items-center justify-center rounded-full bg-primary-700 px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-primary-950/15 transition hover:bg-primary-800 motion-safe:hover:-translate-y-0.5 motion-safe:active:translate-y-0 motion-safe:active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          Message Ella on Facebook
        </a>
        <a
          href="#tax-roadmap"
          class="inline-flex min-h-[44px] cursor-pointer items-center justify-center rounded-full border border-primary-200 bg-white px-6 py-3 text-sm font-semibold text-primary-900 shadow-sm transition hover:border-primary-300 hover:bg-primary-50 motion-safe:hover:-translate-y-0.5 motion-safe:active:translate-y-0 motion-safe:active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          View roadmap
        </a>
      </div>
    </div>

    <div class="relative" data-animate="scale-in" data-delay="0.18s">
      <div class="rounded-lg border border-primary-100 bg-white p-4 shadow-xl shadow-primary-950/10 sm:p-5">
        <div class="flex items-center justify-between border-b border-gray-100 pb-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-700">
              Tax plan workspace
            </p>
            <h2 class="mt-1 font-heading text-xl font-bold text-gray-950">
              Tax advisory roadmap
            </h2>
          </div>
          <span class="rounded-full bg-accent-100 px-3 py-1 text-xs font-semibold text-accent-600 sm:text-sm">
            Active
          </span>
        </div>
        <div class="mt-5 grid gap-3">
          {["Initial meeting", "Tax plan", "Implementation", "Estimates", "Filing"].map((item, index) => (
            <div class="flex min-h-[56px] items-center gap-3 rounded-lg border border-gray-100 bg-gray-50 p-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-100 text-sm font-bold text-primary-800">
                {index + 1}
              </span>
              <span class="text-sm font-semibold text-gray-800">{item}</span>
              <span class="ml-auto hidden h-2 w-16 rounded-full bg-primary-200 sm:block" aria-hidden="true"></span>
            </div>
          ))}
        </div>
      </div>
      <dl class="mt-4 grid gap-3 sm:grid-cols-3">
        {heroMetrics.map((metric) => (
          <div class="rounded-lg border border-primary-100 bg-white p-4 shadow-sm">
            <dt class="text-sm leading-5 text-gray-600">{metric.label}</dt>
            <dd class="mt-2 font-heading text-2xl font-bold text-primary-800">{metric.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>
