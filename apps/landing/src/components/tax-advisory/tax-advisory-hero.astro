---
import { helpPromises } from "@/config/tax-advisory-presentation";
---

<section class="relative overflow-hidden bg-slate-950 pt-24 pb-12 text-white sm:pt-28 lg:pb-16">
  <div class="absolute inset-0 bg-[linear-gradient(135deg,#062f3f_0%,#0f766e_48%,#172554_100%)] opacity-80" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border border-white/15 bg-white p-6 text-slate-950 shadow-2xl shadow-slate-950/30 sm:p-10 lg:p-16" data-animate="fade-up">
      <div class="grid min-h-[520px] gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
        <div class="relative">
          <div class="absolute -left-6 top-0 hidden h-full w-1 rounded-full bg-primary-500 lg:block" aria-hidden="true"></div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary-700">
            Tax advisory services
          </p>
          <h1 class="mt-4 font-heading text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl xl:text-6xl">
            We will help you
          </h1>
          <div class="mt-8 h-1.5 w-40 rounded-full bg-primary-500" aria-hidden="true"></div>
        </div>

        <ul class="grid gap-4">
          {helpPromises.map((item) => (
            <li class="flex gap-4 rounded-lg border border-slate-200 bg-slate-50 p-5 text-base font-semibold leading-7 text-slate-900 shadow-sm sm:text-lg">
              <span class="mt-2.5 h-3 w-3 shrink-0 rounded-full bg-slate-900" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
