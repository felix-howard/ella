---
import { helpPromises, heroMetrics } from "@/config/tax-advisory-presentation";
---

<section class="relative overflow-hidden bg-slate-950 pt-24 pb-12 text-white sm:pt-28 lg:pb-16">
  <div class="absolute inset-0 bg-[linear-gradient(135deg,#062f3f_0%,#0f766e_48%,#172554_100%)] opacity-80" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border border-white/15 bg-white p-6 text-slate-950 shadow-2xl shadow-slate-950/30 sm:p-10 lg:p-14" data-animate="fade-up">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary-700">
            Tax advisory services
          </p>
          <h1 class="mt-4 font-heading text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl xl:text-6xl">
            We will help you
          </h1>
          <p class="mt-6 max-w-xl text-base leading-7 text-slate-600 sm:text-lg">
            A web version of the tax advisory presentation: same meeting content,
            rebuilt as a polished page CPA can open directly in browser.
          </p>
          <dl class="mt-8 grid gap-3 sm:grid-cols-3">
            {heroMetrics.map((metric) => (
              <div class="rounded-lg border border-primary-100 bg-primary-50 p-4">
                <dt class="text-sm leading-5 text-primary-950/70">{metric.label}</dt>
                <dd class="mt-2 font-heading text-2xl font-bold text-primary-800">{metric.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <ul class="grid gap-4">
          {helpPromises.map((item) => (
            <li class="flex gap-4 rounded-lg border border-slate-200 bg-slate-50 p-4 text-base font-semibold leading-7 text-slate-900 sm:text-lg">
              <span class="mt-2.5 h-3 w-3 shrink-0 rounded-full bg-slate-900" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
