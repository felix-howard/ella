---
import { taxAdvisoryStorageKey } from "@/config/tax-advisory-presentation";
---

<script is:inline define:vars={{ taxAdvisoryStorageKey }}>
  (function () {
    try {
      if (localStorage.getItem(taxAdvisoryStorageKey) === "1") {
        document.documentElement.setAttribute("data-tax-advisory-auth", "ok");
      }
    } catch (_error) {}
  })();
</script>

<style is:global>
  html[data-tax-advisory-auth="ok"] #tax-advisory-gate {
    display: none;
  }

  html:not([data-tax-advisory-auth="ok"]) .tax-advisory-content {
    display: none;
  }

  html:not([data-tax-advisory-auth="ok"]) body > a[href="#main-content"],
  html:not([data-tax-advisory-auth="ok"]) body > header,
  html:not([data-tax-advisory-auth="ok"]) body > footer,
  html:not([data-tax-advisory-auth="ok"]) #mobile-backdrop,
  html:not([data-tax-advisory-auth="ok"]) #mobile-menu {
    display: none;
  }
</style>

<div
  id="tax-advisory-gate"
  class="fixed inset-0 z-[100] flex items-start justify-center overflow-y-auto bg-[#f6fbf8] px-5 py-6 sm:px-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="tax-advisory-gate-title"
  aria-describedby="tax-advisory-gate-description"
>
  <form
    id="tax-advisory-gate-form"
    class="w-full max-w-md rounded-lg border border-primary-100 bg-white p-6 shadow-xl shadow-primary-950/10"
  >
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary-700">
      Private preview
    </p>
    <h1
      id="tax-advisory-gate-title"
      class="mt-3 font-heading text-2xl font-bold tracking-tight text-gray-950"
    >
      Ella tax advisory page
    </h1>
    <p id="tax-advisory-gate-description" class="mt-3 text-sm leading-6 text-gray-600">
      Enter the preview password to view this noindex presentation page. Do not use this
      preview gate for confidential taxpayer information.
    </p>

    <label for="tax-advisory-password" class="mt-6 block text-sm font-semibold text-gray-800">
      Password
    </label>
    <input
      id="tax-advisory-password"
      type="password"
      autocomplete="off"
      aria-describedby="tax-advisory-gate-error"
      class="mt-2 min-h-[44px] w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-950 outline-none transition focus:border-primary-500 focus:ring-4 focus:ring-primary-500/15"
    />
    <p
      id="tax-advisory-gate-error"
      hidden
      aria-live="polite"
      class="mt-2 text-sm font-medium text-red-700"
    >
      Incorrect password. Try again.
    </p>
    <button
      type="submit"
      class="mt-5 inline-flex min-h-[44px] w-full cursor-pointer items-center justify-center rounded-full bg-primary-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-800 motion-safe:active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
    >
      Continue
    </button>
  </form>
</div>

<script>
  import { initTaxAdvisoryPasswordGate } from "@/scripts/tax-advisory-password-gate";

  document.addEventListener("DOMContentLoaded", initTaxAdvisoryPasswordGate);
</script>
