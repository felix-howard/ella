---
import {
  actionItems,
  clientResponsibilities,
  nextSteps,
} from "@/config/tax-advisory-presentation";
---

<section class="bg-[#9a5a82] py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg bg-white p-6 shadow-2xl shadow-slate-950/20 sm:p-10" data-animate="fade-up">
      <h2 class="font-heading text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl">
        We need your help to
      </h2>
      <ul class="mt-10 grid gap-5 text-xl font-medium leading-8 text-slate-950 sm:text-2xl">
        {clientResponsibilities.map((item) => (
          <li class="flex gap-5">
            <span class="mt-3 h-3 w-3 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="bg-slate-700 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border-2 border-white/80 p-5 sm:p-8" data-animate="fade-up">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="rounded-lg bg-white p-6 sm:p-10">
          <h2 class="font-heading text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl">
            Action items
          </h2>
          <ul class="mt-10 grid gap-8 text-2xl font-medium leading-tight text-slate-950">
            {actionItems.map((item) => (
              <li class="flex gap-5">
                <span class="mt-3 h-3 w-3 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg bg-white p-6 sm:p-8">
          <h3 class="font-heading text-3xl font-extrabold text-slate-950">Next Steps</h3>
          <div class="mt-8 grid gap-8 md:grid-cols-2">
            <div>
              <h4 class="font-heading text-xl font-bold text-slate-950">For you</h4>
              <ul class="mt-5 grid gap-4 text-lg leading-7 text-slate-800">
                {nextSteps.forYou.map((item) => (
                  <li class="flex gap-4">
                    <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h4 class="font-heading text-xl font-bold text-slate-950">For us</h4>
              <ul class="mt-5 grid gap-4 text-lg leading-7 text-slate-800">
                {nextSteps.forUs.map((item) => (
                  <li class="flex gap-4">
                    <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
