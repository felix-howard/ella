---
/**
 * Animated stats bar showing key metrics in a responsive grid.
 * Counter animation wired via data-count attribute (activated by scroll-observer).
 * Aurora/dark theme variant with glowing emerald numbers.
 */
interface StatItem {
  value: number;
  label: string;
  suffix?: string;
}

interface Props {
  stats: StatItem[];
  variant?: "dark" | "light";
}

const { stats, variant = "dark" } = Astro.props;
const isLight = variant === "light";
const formatValue = (stat: StatItem) => `${stat.value.toLocaleString()}${stat.suffix ?? ""}`;
---

<div class="grid grid-cols-2 gap-8 md:grid-cols-4" data-stagger>
  {stats.map((stat) => (
    <div class="text-center" data-animate="fade-up">
      <p
        class:list={[
          "text-3xl font-bold sm:text-4xl font-heading",
          isLight ? "text-primary-700" : "text-white",
        ]}
        style={isLight ? "" : "text-shadow: 0 12px 30px rgba(14, 165, 233, 0.32);"}
        data-count={stat.value}
        data-suffix={stat.suffix ?? ""}
      >
        {formatValue(stat)}
      </p>
      <p class:list={["mt-2 text-sm", isLight ? "text-slate-600" : "text-sky-100/80"]}>{stat.label}</p>
    </div>
  ))}
</div>
