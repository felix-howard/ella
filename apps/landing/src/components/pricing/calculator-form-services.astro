---
/**
 * Calculator form — Sections B-E (add-on services).
 * Cash Plan, Audit Protection, One-time services, Sales tax monitoring.
 * Inputs expose `data-calc-input` keys matching `CalcInput` (phase 01).
 */
import {
  AUDIT_PROTECTION,
  CASH_PLAN,
  ONE_TIME,
  SALES_TAX_MONITORING_MONTHLY,
} from "@/config/pricing";
import {
  headingCls,
  hintCls,
  inputCls,
  labelCls,
  rateInputCls,
  sectionCls,
} from "./calculator-form-styles";

/**
 * One-time services form rows. Single-rate rows render one editable rate
 * input; the business tax return row is special-cased (`splitRate`) and
 * renders two inputs — Federal + State — both operator-editable.
 */
type SingleRateRow = {
  kind: "single";
  qtyKey: "startLlc" | "holdingLlcNew" | "holdingLlcModify" | "personalTaxReturn";
  label: string;
  rateKey: keyof typeof ONE_TIME;
  hint?: string;
};
type SplitRateRow = {
  kind: "split";
  qtyKey: "businessTaxReturn";
  label: string;
};
type OneTimeRow = SingleRateRow | SplitRateRow;

const oneTimeRows: OneTimeRow[] = [
  {
    kind: "single",
    qtyKey: "startLlc",
    label: "Start LLC",
    rateKey: "startLlc",
    hint: "Excludes state filing fee (paid separately)",
  },
  { kind: "single", qtyKey: "holdingLlcNew", label: "Holding LLC (new)", rateKey: "holdingLlcNew" },
  { kind: "single", qtyKey: "holdingLlcModify", label: "Re-structure LLC basic", rateKey: "holdingLlcModify" },
  { kind: "single", qtyKey: "personalTaxReturn", label: "Personal tax return", rateKey: "personalTaxReturn" },
  { kind: "split", qtyKey: "businessTaxReturn", label: "Business tax return" },
];
---

<!-- Section B — Cash Plan -->
<div class={sectionCls}>
  <label class="flex cursor-pointer items-start gap-3">
    <input
      type="checkbox"
      name="cashPlanEnabled"
      data-calc-input="cashPlan.enabled"
      class="mt-1 h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
    />
    <span>
      <span class={headingCls}>Enable Cash Plan</span>
      <span class="mt-0.5 block text-sm text-gray-500">
        $<input
          type="text"
          inputmode="numeric"
          pattern="\d*"
          maxlength="6"
          value={CASH_PLAN.setup}
          data-calc-input="rates.cashPlan.setup"
          data-stop-label-toggle
          class={rateInputCls}
          aria-label="Cash Plan setup fee"
        /> setup · $<input
          type="text"
          inputmode="numeric"
          pattern="\d*"
          maxlength="4"
          value={CASH_PLAN.perEmployeeMonthly}
          data-calc-input="rates.cashPlan.perEmployeeMonthly"
          data-stop-label-toggle
          class={rateInputCls}
          aria-label="Cash Plan per employee monthly"
        />/emp + $<input
          type="text"
          inputmode="numeric"
          pattern="\d*"
          maxlength="4"
          value={CASH_PLAN.perOwnerMonthly}
          data-calc-input="rates.cashPlan.perOwnerMonthly"
          data-stop-label-toggle
          class={rateInputCls}
          aria-label="Cash Plan per owner monthly"
        />/owner monthly
      </span>
    </span>
  </label>
  <div class="mt-4 space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="calc-cash-emp" class={labelCls}>Employees enrolled</label>
        <input
          id="calc-cash-emp"
          type="text"
          name="cashPlanEmployees"
          inputmode="numeric"
          pattern="\d*"
          maxlength="3"
          placeholder="0"
          data-calc-input="cashPlan.employees"
          class={inputCls}
        />
      </div>
      <div>
        <label for="calc-cash-own" class={labelCls}>Owners / shareholders</label>
        <input
          id="calc-cash-own"
          type="text"
          name="cashPlanOwners"
          inputmode="numeric"
          pattern="\d*"
          maxlength="2"
          placeholder="0"
          data-calc-input="cashPlan.owners"
          class={inputCls}
        />
      </div>
    </div>
  </div>
</div>

<!-- Section C — Audit Protection -->
<div class={sectionCls}>
  <label class="flex cursor-pointer items-start gap-3">
    <input
      type="checkbox"
      name="auditProtection"
      data-calc-input="auditProtection"
      class="mt-1 h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
    />
    <span>
      <span class={headingCls}>Enable Audit Detection</span>
      <span class="mt-0.5 block text-sm text-gray-500">
        +$<input
          type="text"
          inputmode="numeric"
          pattern="\d*"
          maxlength="5"
          value={AUDIT_PROTECTION.monthly}
          data-calc-input="rates.auditProtection.monthly"
          data-stop-label-toggle
          class={rateInputCls}
          aria-label="Audit Protection monthly"
        />/mo · $<input
          type="text"
          inputmode="numeric"
          pattern="\d*"
          maxlength="6"
          value={AUDIT_PROTECTION.setup}
          data-calc-input="rates.auditProtection.setup"
          data-stop-label-toggle
          class={rateInputCls}
          aria-label="Audit Protection setup"
        /> one-time setup
      </span>
    </span>
  </label>
</div>

<!-- Section D — One-time services -->
<div class={sectionCls}>
  <div>
    <span class={headingCls}>One-time services</span>
    <p class={hintCls}>Add LLC formation, tax returns, and other fixed-fee work.</p>
  </div>
  <ul class="mt-4 space-y-3">
    {oneTimeRows.map((row) => (
      <li class="grid gap-2 sm:grid-cols-[1fr_120px] sm:items-center">
        <div>
          <label for={`calc-onetime-${row.qtyKey}`} class="text-sm font-medium text-gray-900">
            {row.label}
            {row.kind === "single" && (
              <span class="ml-2 text-xs text-gray-500">
                $<input
                  type="text"
                  inputmode="numeric"
                  pattern="\d*"
                  maxlength="6"
                  value={ONE_TIME[row.rateKey]}
                  data-calc-input={`rates.oneTime.${row.rateKey}`}
                  class={rateInputCls}
                  aria-label={`${row.label} rate`}
                /> each
              </span>
            )}
            {row.kind === "split" && (
              <span class="ml-2 text-xs text-gray-500">
                $<input
                  type="text"
                  inputmode="numeric"
                  pattern="\d*"
                  maxlength="6"
                  value={ONE_TIME.businessTaxReturnFederal}
                  data-calc-input="rates.oneTime.businessTaxReturnFederal"
                  class={rateInputCls}
                  aria-label="Business tax return federal rate"
                /> Federal + $<input
                  type="text"
                  inputmode="numeric"
                  pattern="\d*"
                  maxlength="6"
                  value={ONE_TIME.businessTaxReturnState}
                  data-calc-input="rates.oneTime.businessTaxReturnState"
                  class={rateInputCls}
                  aria-label="Business tax return state rate"
                /> State
              </span>
            )}
          </label>
          {row.kind === "single" && row.hint && (
            <p class="text-xs text-gray-500">{row.hint}</p>
          )}
        </div>
        <input
          id={`calc-onetime-${row.qtyKey}`}
          type="text"
          name={`oneTime_${row.qtyKey}`}
          inputmode="numeric"
          pattern="\d*"
          maxlength="2"
          placeholder="0"
          aria-label={`${row.label} quantity`}
          data-calc-input={`oneTime.${row.qtyKey}`}
          class={inputCls}
        />
      </li>
    ))}
  </ul>
</div>

<!-- Section E — Ongoing extras -->
<div class={sectionCls}>
  <label for="calc-sales-tax" class={labelCls}>Shops for sales tax monitoring</label>
  <input
    id="calc-sales-tax"
    type="text"
    name="salesTaxShops"
    inputmode="numeric"
    pattern="\d*"
    maxlength="3"
    placeholder="0"
    aria-describedby="calc-sales-tax-hint"
    data-calc-input="salesTaxShops"
    class={inputCls}
  />
  <p id="calc-sales-tax-hint" class={hintCls}>
    +$<input
      type="text"
      inputmode="numeric"
      pattern="\d*"
      maxlength="4"
      value={SALES_TAX_MONITORING_MONTHLY}
      data-calc-input="rates.salesTaxMonitoringMonthly"
      class={rateInputCls}
      aria-label="Sales tax monitoring monthly rate per shop"
    />/mo per shop monitored.
  </p>
</div>

<script>
  document.querySelectorAll<HTMLInputElement>("[data-stop-label-toggle]").forEach((input) => {
    input.addEventListener("click", (event) => {
      event.stopPropagation();
    });
  });
</script>
