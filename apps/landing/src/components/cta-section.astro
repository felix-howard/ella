---
/**
 * Full-width service inquiry CTA.
 * Used across pages for consistent bottom CTA.
 */
import { siteConfig } from "@/config/site";

interface Props {
  title: string;
  description?: string;
  idPrefix?: string;
  /** Legacy props kept for backward compatibility but no longer used */
  buttonText?: string;
  buttonHref?: string;
}

const { title, description } = Astro.props;
---

<section class="service-section relative overflow-hidden py-16 sm:py-24">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center" data-animate="fade-up">
      <h2 class="text-2xl font-bold text-slate-950 sm:text-3xl md:text-4xl font-heading">
        {title}
      </h2>
      {description && (
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
          {description}
        </p>
      )}
    </div>

    <div class="mt-8 flex justify-center sm:mt-12" data-animate="fade-up">
      <a
        class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-accent-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-orange-700/20 transition-colors hover:bg-accent-800"
        href={siteConfig.cta.primaryHref}
      >
        {siteConfig.cta.primaryLabel}
      </a>
    </div>
  </div>
</section>
