---
/**
 * Online workflow card grid shared by landing pages.
 */
import IconCard from "@/components/icon-card.astro";
import SectionHeading from "@/components/section-heading.astro";
import type { SoftwareCard } from "@/config/software-content";

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  cards: SoftwareCard[];
}

const { eyebrow, title, subtitle, cards } = Astro.props;
---

<section class="bg-white py-16 sm:py-24" aria-label={title}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading eyebrow={eyebrow} title={title} subtitle={subtitle} />
    <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
      {cards.map((card) => (
        <div data-animate="fade-up">
          <IconCard
            icon={card.icon}
            title={card.title}
            description={card.description}
            variant="primary"
          />
        </div>
      ))}
    </div>
  </div>
</section>
