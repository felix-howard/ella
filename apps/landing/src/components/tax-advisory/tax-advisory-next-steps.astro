---
import {
  actionItems,
  clientResponsibilities,
  nextSteps,
} from "@/config/tax-advisory-presentation";
---

<section class="bg-primary-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border border-primary-100 bg-white p-6 shadow-sm sm:p-10" data-animate="fade-up">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-800">
        Client responsibilities
      </p>
      <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
        We need your help to
      </h2>
      <ul class="mt-8 grid gap-4 text-base font-medium leading-7 text-slate-800 sm:grid-cols-2">
        {clientResponsibilities.map((item) => (
          <li class="flex gap-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
            <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-primary-600" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="section-dark py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="rounded-lg border border-white/10 bg-white/10 p-5 sm:p-8" data-animate="fade-up">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="rounded-lg bg-white p-6 sm:p-10">
          <h2 class="font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
            Action items
          </h2>
          <ul class="mt-8 grid gap-4 text-lg font-semibold leading-7 text-slate-900">
            {actionItems.map((item) => (
              <li class="flex gap-4">
                <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-primary-600" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg bg-white p-6 sm:p-8">
          <h3 class="font-heading text-3xl font-bold text-slate-950">Next steps</h3>
          <div class="mt-8 grid gap-8 md:grid-cols-2">
            <div>
              <h4 class="font-heading text-xl font-bold text-slate-950">For you</h4>
              <ul class="mt-5 grid gap-4 text-lg leading-7 text-slate-800">
                {nextSteps.forYou.map((item) => (
                  <li class="flex gap-4">
                    <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h4 class="font-heading text-xl font-bold text-slate-950">For us</h4>
              <ul class="mt-5 grid gap-4 text-lg leading-7 text-slate-800">
                {nextSteps.forUs.map((item) => (
                  <li class="flex gap-4">
                    <span class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-950" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
