---
/**
 * Sticky responsive navbar with scroll-based floating pill animation.
 * Initial: full-width transparent header.
 * On scroll: shrinks into a floating rounded container with light gradient bg.
 * Includes Login link, mobile menu, and accessibility features.
 */
import { navLinks } from "@/config/navigation";
import { siteConfig } from "@/config/site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
// Normalize path: strip trailing slash for consistent comparison (production serves /about/ vs /about)
const normalizedPath = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");
---

<!-- Backdrop overlay for mobile menu -->
<div
  id="mobile-backdrop"
  class="fixed inset-0 z-[55] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
></div>

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out"
  aria-label="Main navigation"
>
  <!-- Outer wrapper for centering the floating pill -->
  <div id="nav-pill" class="nav-pill-initial transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
      <!-- Logo -->
      <a href="/" class="shrink-0 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500">
        <img src="/ella-logo.png" alt={siteConfig.name} class="h-8 object-contain transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]" />
      </a>

      <!-- Desktop nav links (centered) -->
      <nav class="hidden items-center gap-5 lg:gap-8 md:flex">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-full px-3 py-2 text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500",
              normalizedPath === link.href
                ? "bg-primary-50 text-primary-700"
                : "text-slate-600 hover:bg-white hover:text-slate-950",
            ]}
            aria-current={normalizedPath === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: primary CTA + mobile menu -->
      <div class="flex items-center gap-3 md:gap-5">
        <a
          href={siteConfig.cta.navHref}
          class="whitespace-nowrap rounded-full bg-primary-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-[background-color,box-shadow,transform] hover:bg-primary-800 hover:shadow-lg hover:shadow-primary-600/25 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 md:px-5 md:py-2.5"
        >
          {siteConfig.cta.navLabel}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="flex h-10 w-10 min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center rounded-lg text-slate-600 transition-[background-color,transform] hover:bg-slate-100 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg
            id="hamburger-icon"
            class="h-6 w-6 transition-all duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile slide-in menu (right to left) -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 bottom-0 z-[60] w-72 translate-x-full bg-white shadow-2xl transition-transform duration-300 ease-out md:hidden"
  aria-hidden="true"
  inert
>
  <!-- Close button -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
    <span class="text-lg font-semibold text-gray-900">Menu</span>
    <button
      id="mobile-menu-close"
      class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg text-slate-600 transition-[background-color,transform] hover:bg-slate-100 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
      aria-label="Close menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex flex-col gap-1 px-4 py-4">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          "rounded-lg px-4 py-3 text-base font-medium transition-[background-color,color,transform] active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500",
          normalizedPath === link.href
            ? "bg-primary-50 text-primary-700"
            : "text-slate-600 hover:bg-slate-50 hover:text-slate-950",
        ]}
        aria-current={normalizedPath === link.href ? "page" : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<script>
  import { initNavbar } from "@/scripts/navbar";

  initNavbar();
</script>
