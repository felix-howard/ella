---
import {
  businessStrategies,
  individualStrategies,
} from "@/config/tax-advisory-presentation";
---

<section class="section-dark py-16 text-white sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div data-animate="fade-up">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-200">
          Individual
        </p>
        <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">
          Individual strategy review
        </h2>
        <p class="mt-4 max-w-xl text-base leading-7 text-white/70">
          Topics are screened against the client facts before any recommendation moves to
          implementation.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2" data-stagger>
        {individualStrategies.map((strategy) => (
          <article class="rounded-lg border border-white/10 bg-white/10 p-4 shadow-sm" data-animate="fade-up">
            <p class="font-heading text-lg font-bold leading-7 text-white">{strategy}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-20 grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
      <div data-animate="fade-up">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-200">
          Business
        </p>
        <h2 class="mt-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl">
          Business
        </h2>
      </div>
      <div class="grid gap-4" data-stagger>
        {businessStrategies.map((strategy) => (
          <article
            class="rounded-lg border border-white/10 bg-white p-5 font-heading text-2xl font-bold tracking-tight text-slate-950 shadow-sm sm:text-3xl"
            data-animate="fade-up"
          >
            {strategy}
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
