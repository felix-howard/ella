<section
  class="space-y-3 rounded-xl border border-neutral-border bg-white p-4"
  aria-labelledby="payment-link-title"
  data-payment-link="form"
>
  <div>
    <h4 id="payment-link-title" class="text-sm font-semibold text-gray-900">
      Payment link
    </h4>
    <p class="mt-1 text-xs leading-5 text-gray-500">
      Create a Stripe Checkout URL for this quote.
    </p>
  </div>

  <label class="block text-xs font-semibold uppercase tracking-wide text-gray-500">
    Customer email optional
    <input
      type="email"
      autocomplete="email"
      inputmode="email"
      data-payment-link="customerEmail"
      class="mt-1 w-full rounded-lg border border-neutral-border bg-white px-3 py-2 text-base text-gray-900 placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 md:text-sm"
      placeholder="client@example.com"
    />
  </label>

  <div class="grid gap-3 sm:grid-cols-2">
    <label class="block text-xs font-semibold uppercase tracking-wide text-gray-500">
      Customer name
      <input
        type="text"
        autocomplete="name"
        data-payment-link="customerName"
        class="mt-1 w-full rounded-lg border border-neutral-border bg-white px-3 py-2 text-base text-gray-900 placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 md:text-sm"
        placeholder="Jane Nguyen"
      />
    </label>
    <label class="block text-xs font-semibold uppercase tracking-wide text-gray-500">
      Business
      <input
        type="text"
        autocomplete="organization"
        data-payment-link="businessName"
        class="mt-1 w-full rounded-lg border border-neutral-border bg-white px-3 py-2 text-base text-gray-900 placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 md:text-sm"
        placeholder="Salon LLC"
      />
    </label>
  </div>

  <label class="block text-xs font-semibold uppercase tracking-wide text-gray-500">
    Staff access token
    <input
      type="password"
      autocomplete="off"
      spellcheck="false"
      data-payment-link="staffToken"
      class="mt-1 w-full rounded-lg border border-neutral-border bg-white px-3 py-2 text-base text-gray-900 placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 md:text-sm"
      placeholder="Bearer token"
    />
  </label>

  <button class="btn-primary w-full" type="button" data-payment-link="create">
    Create payment link
  </button>

  <p
    class="text-sm font-medium text-gray-600"
    role="status"
    aria-live="polite"
    data-payment-link="status"
  ></p>

  <div hidden class="space-y-3" data-payment-link="success">
    <label class="block text-xs font-semibold uppercase tracking-wide text-gray-500">
      Stripe Checkout URL
      <input
        type="url"
        readonly
        data-payment-link="checkoutUrl"
        class="mt-1 w-full overflow-hidden text-ellipsis rounded-lg border border-neutral-border bg-neutral-muted px-3 py-2 text-sm text-gray-900"
      />
    </label>
    <div class="grid gap-2 sm:grid-cols-2">
      <button class="btn-secondary w-full" type="button" data-payment-link="copy">
        Copy link
      </button>
      <a
        class="btn-secondary w-full"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        data-payment-link="open"
      >
        Open link
      </a>
    </div>
  </div>
</section>
