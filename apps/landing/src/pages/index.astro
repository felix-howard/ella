---
/**
 * Landing page — introduces Ella to visitors.
 * Sections: Hero, Stats, Features, How It Works, Testimonials, CTA + Contact Form.
 * Aurora UI redesign: glassmorphism, aurora gradients, premium typography.
 */
import BaseLayout from "@/layouts/base-layout.astro";
import HeadSEO from "@/components/seo/head-seo.astro";
import SectionHeading from "@/components/section-heading.astro";
import TestimonialCard from "@/components/testimonial-card.astro";
import StatsBar from "@/components/stats-bar.astro";
import ContactForm from "@/components/contact-form.astro";
import {
  organizationSchema,
  websiteSchema,
  softwareApplicationSchema,
  aggregateRatingSchema,
} from "@/components/seo/structured-data";

const structuredData = [
  organizationSchema(),
  websiteSchema(),
  softwareApplicationSchema(),
  aggregateRatingSchema(),
];

/* Stats data for the trust bar */
const stats = [
  { value: 1000000, label: "Documents Processed", suffix: "+" },
  { value: 500, label: "Tax Firms", suffix: "+" },
  { value: 99, label: "Accuracy Rate", suffix: "%" },
  { value: 80, label: "Time Saved", suffix: "%" },
];

/* How it works — 3-step SMS-focused process */
const steps = [
  {
    step: "1",
    title: "Client Texts Photo",
    description:
      "Client snaps a photo of their tax document and texts it to your firm's Ella number. No app required.",
  },
  {
    step: "2",
    title: "AI Classifies & Renames",
    description:
      "Ella classifies the document, extracts data, and renames it: '2024_W2_Employer_ClientName.pdf'.",
  },
  {
    step: "3",
    title: "Review & Prepare",
    description:
      "Your team reviews organized documents, completes the checklist, and prepares the return.",
  },
];

/* Testimonials — quotes from CPAs/Tax Preparers */
const testimonials = [
  {
    quote:
      "Ella cut our document collection time by 75%. Clients love the magic link portal.",
    author: "Tuyet Nguyen",
    role: "CPA, Nguyen & Associates",
  },
  {
    quote:
      "The AI classification is incredibly accurate. We barely need to manually review anymore.",
    author: "Nancy Nguyen",
    role: "Tax Preparer, TaxPro Solutions",
  },
  {
    quote:
      "Game changer for our firm. Team collaboration features keep everyone on the same page.",
    author: "Rebecca Martinez",
    role: "Partner, Martinez Tax Group",
  },
];
---

<BaseLayout>
  <HeadSEO
    slot="head"
    title="Ella - AI-Powered Tax Document Management | Automate Your Workflow"
    description="Clients text tax docs directly to your Ella number. AI auto-renames messy uploads into organized files. Trusted by 500+ tax firms."
    structuredData={structuredData}
  />

  <main>
    <!-- ═══ Hero Section ═══ -->
    <section
      class="relative flex min-h-[80vh] items-center justify-center overflow-hidden pt-16 sm:min-h-[90vh]"
    >
      <!-- Layer 1: Aurora mesh gradient background -->
      <div
        class="pointer-events-none absolute inset-0 aurora-bg opacity-90"
        aria-hidden="true"
      ></div>

      <!-- Layer 2: Dot grid pattern overlay -->
      <div
        class="pointer-events-none absolute inset-0 grid-pattern"
        aria-hidden="true"
      ></div>

      <!-- Layer 3: Bottom fade to white -->
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-white to-transparent"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24 text-center">
        <p
          class="mb-4 inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-widest text-white backdrop-blur-sm"
          data-animate="fade-up"
        >
          SMS-First Document Collection
        </p>
        <h1
          class="mx-auto max-w-4xl text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading"
          data-animate="fade-up"
          data-delay="0.1s"
        >
          Automate tax document collection and classification
          <span class="gradient-text" style="background: linear-gradient(135deg, #A7F3D0, #6EE7B7, #34D399); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">in seconds</span>
        </h1>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/80 md:text-xl"
          data-animate="fade-up"
          data-delay="0.2s"
        >
          Ella transforms messy phone photos into organized, named files
          automatically. AI classification + auto-rename included.
        </p>

        <!-- Dual CTAs with glow -->
        <div
          class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
          data-animate="fade-up"
          data-delay="0.3s"
        >
          <a
            href="https://www.facebook.com/andy.hayven"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-white px-8 py-3.5 text-base font-semibold text-primary-700 shadow-lg transition-all hover:shadow-xl hover:shadow-white/25 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Request a Demo
          </a>
          <a
            href="#how-it-works"
            class="rounded-full border border-white/30 bg-white/10 px-8 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            See How It Works
          </a>
        </div>

        <!-- Product visual with glass frame + glow -->
        <div
          class="mx-auto mt-16 max-w-4xl overflow-hidden rounded-xl border border-white/20 bg-white/5 p-2 shadow-2xl backdrop-blur-sm glow-aurora"
          data-animate="scale-in"
          data-delay="0.4s"
        >
          <img
            src="/assets/Screenshot_369.png"
            alt="Ella client dashboard showing organized tax documents by category"
            class="w-full rounded-lg"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ═══ Features / Problem-Solution Section ═══ -->
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <!-- Section intro -->
        <div class="mx-auto max-w-3xl text-center" data-animate="fade-up">
          <p class="text-sm font-semibold uppercase tracking-widest gradient-text">
            Why CPAs Choose Ella
          </p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl font-heading">
            Your time is too valuable for document chaos
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Stop chasing documents, stop manual data entry, stop the endless back-and-forth.
            Let AI handle the busywork so you can focus on what actually matters — serving your clients.
          </p>
        </div>

        <!-- 3 Feature Cards with glass effect -->
        <div class="mt-12 grid gap-8 sm:mt-20 sm:gap-12 lg:grid-cols-3" data-stagger>
          <!-- Card 1: Easy Collection -->
          <div class="group" data-animate="fade-up">
            <div class="glass-card-light overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src="/assets/Screenshot_379.png"
                  alt="SMS messaging interface showing clients sending documents directly via text"
                  class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg text-white" style="background: linear-gradient(135deg, #059669, #3B82F6);">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
                  </svg>
                </div>
                <h3 class="mt-4 text-xl font-semibold text-gray-900 font-heading">
                  Clients Send Docs in Seconds
                </h3>
                <p class="mt-2 text-gray-600">
                  No app downloads. No portal logins. Clients simply text photos or click a passwordless link.
                  Documents flow directly into Ella — even via MMS.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 2: Organized Documents -->
          <div class="group" data-animate="fade-up">
            <div class="glass-card-light overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src="/assets/Screenshot_369.png"
                  alt="Client dashboard showing documents automatically organized by category"
                  class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg text-white" style="background: linear-gradient(135deg, #3B82F6, #8B5CF6);">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />
                  </svg>
                </div>
                <h3 class="mt-4 text-xl font-semibold text-gray-900 font-heading">
                  Chaos → Organized Instantly
                </h3>
                <p class="mt-2 text-gray-600">
                  "IMG_4827.jpg" becomes "2024_W2_Amazon_JohnSmith.pdf". AI classifies 89+ document types,
                  auto-renames, and organizes everything by client and category.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 3: AI Data Extraction -->
          <div class="group" data-animate="fade-up">
            <div class="glass-card-light overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src="/assets/Screenshot_370.png"
                  alt="AI extracting structured data from a 1099-NEC tax form"
                  class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg text-white" style="background: linear-gradient(135deg, #8B5CF6, #06B6D4);">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
                  </svg>
                </div>
                <h3 class="mt-4 text-xl font-semibold text-gray-900 font-heading">
                  Data Extracted, Ready for Entry
                </h3>
                <p class="mt-2 text-gray-600">
                  Stop squinting at blurry photos and typing manually. AI reads W-2s, 1099s, and more —
                  extracting income, employer info, and tax details for one-click data entry.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Bottom CTA -->
        <div class="mt-16 text-center" data-animate="fade-up">
          <p class="text-lg font-medium text-gray-900">
            Document chasing, manual downloads, and endless back-and-forth?
          </p>
          <p class="mt-1 text-gray-600">
            That's the old way. Ella automates it all so you can focus on advisory work that actually grows your firm.
          </p>
          <a
            href="https://www.facebook.com/andy.hayven"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-primary-700 hover:shadow-lg hover:shadow-primary-600/25 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
          >
            See Ella in Action
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ Showcase Folder: Sticky-stacking feature cards ═══ -->
    <div class="showcase-folder">
      <!-- Folder tab -->
      <div class="showcase-folder-tab">
        <span class="text-sm font-semibold text-gray-600 font-heading">How Ella Works</span>
      </div>

    <!-- ═══ Showcase 1: SMS Document Collection ═══ -->
    <section class="showcase-card showcase-card-1 py-16 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <!-- Left: Text -->
          <div data-animate="fade-up">
            <p class="text-sm font-semibold uppercase tracking-widest gradient-text">
              Collection
            </p>
            <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl font-heading">
              Clients text docs, Ella handles the rest
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-gray-600">
              No app downloads needed. Client texts a photo of their tax document — Ella receives it, classifies it, and auto-files it to the right client folder. It's that simple.
            </p>
          </div>
          <!-- Right: Phone mockup animation -->
          <div class="showcase-mockup" data-animate="fade-up" data-delay="0.2s" data-loop-duration="5000">
            <div class="showcase-frame p-6">
              <div class="mx-auto max-w-[280px]">
                <!-- Phone header -->
                <div class="flex items-center gap-3 border-b border-gray-100 pb-3">
                  <div class="flex h-9 w-9 items-center justify-center rounded-full" style="background: linear-gradient(135deg, #059669, #3B82F6);">
                    <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-900">Ella</p>
                    <p class="text-xs text-gray-500">Tax Document Assistant</p>
                  </div>
                </div>
                <!-- Messages -->
                <div class="mt-4 space-y-3">
                  <div class="flex justify-end" data-anim data-sc-anim="message-arrive 0.5s ease-out 0.3s both">
                    <div class="max-w-[200px] rounded-2xl rounded-br-md bg-blue-500 px-3.5 py-2.5">
                      <div class="mb-1.5 flex h-16 items-center justify-center rounded-lg bg-blue-400/50">
                        <svg class="h-6 w-6 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      </div>
                      <p class="text-xs text-white/90">W2_photo.jpg</p>
                    </div>
                  </div>
                  <div class="flex justify-start" data-anim data-sc-anim="message-arrive 0.5s ease-out 1s both">
                    <div class="max-w-[210px] rounded-2xl rounded-bl-md bg-gray-100 px-3.5 py-2.5">
                      <p class="text-xs text-gray-800">
                        <span class="font-medium text-emerald-600">✓ Received!</span> Processing your document...
                      </p>
                    </div>
                  </div>
                  <div class="flex justify-start" data-anim data-sc-anim="message-arrive 0.5s ease-out 1.8s both">
                    <div class="max-w-[210px] rounded-2xl rounded-bl-md bg-gray-100 px-3.5 py-2.5">
                      <div class="flex items-start gap-2">
                        <span data-anim data-sc-anim="check-pop 0.4s ease-out 2.5s both" class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                          <svg class="h-2.5 w-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        </span>
                        <p class="text-xs text-gray-800">
                          <span class="font-medium">Filed to</span><br />
                          <span class="text-gray-500">John Smith / W-2</span>
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Showcase 2: AI Document Classification ═══ -->
    <section class="showcase-card showcase-card-2 py-16 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <!-- Left: Text -->
          <div data-animate="fade-up">
            <p class="text-sm font-semibold uppercase tracking-widest gradient-text">
              Classification
            </p>
            <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl font-heading">
              Every document identified & renamed automatically
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-gray-600">
              IMG_4827.jpg becomes 2024_W2_Amazon_JohnSmith.pdf. AI classifies 89+ document types instantly — no manual sorting, no guessing.
            </p>
          </div>
          <!-- Right: Classification mockup -->
          <div class="showcase-mockup" data-animate="fade-up" data-delay="0.2s" data-loop-duration="5500">
            <div class="showcase-frame p-6">
              <div class="mx-auto max-w-[320px]">
                <!-- Blurry doc that sharpens -->
                <div data-anim data-sc-anim="doc-sharpen 1s ease-out 0.3s both" class="mb-5 flex h-40 items-center justify-center rounded-xl bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-200/60">
                  <div class="text-center">
                    <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                    <p class="mt-1 text-xs text-gray-400">IMG_4827.jpg</p>
                  </div>
                </div>
                <!-- Classification badges -->
                <div class="space-y-2.5">
                  <div data-anim data-sc-anim="badge-slide-in 0.4s ease-out 1.2s both" class="flex items-center gap-2.5">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    </span>
                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700 border border-emerald-100">Document Type: W-2</span>
                  </div>
                  <div data-anim data-sc-anim="badge-slide-in 0.4s ease-out 1.7s both" class="flex items-center gap-2.5">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-500 text-white">
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    </span>
                    <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 border border-blue-100">Tax Year: 2024</span>
                  </div>
                  <div data-anim data-sc-anim="badge-slide-in 0.4s ease-out 2.2s both" class="flex items-center gap-2.5">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-purple-500 text-white">
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    </span>
                    <span class="rounded-full bg-purple-50 px-3 py-1 text-xs font-medium text-purple-700 border border-purple-100">Employer: Amazon</span>
                  </div>
                  <div data-anim data-sc-anim="badge-slide-in 0.4s ease-out 2.7s both" class="flex items-center gap-2.5">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-cyan-500 text-white">
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    </span>
                    <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-700 border border-cyan-100">Client: John Smith</span>
                  </div>
                </div>
                <!-- Renamed filename -->
