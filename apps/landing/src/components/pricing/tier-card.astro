---
/**
 * Pricing tier card — display-only marketing card for Basic/Pro/VIP tiers.
 * Prices shown here are bundled reference prices (see pricing-constants.ts
 * `marketingMonthly`); exact cost is computed by the calculator below.
 * Pro tier gets `popular=true` for the "Most Popular" badge + emphasis.
 */
import { checkPath } from "@/lib/icons";

interface Props {
  id: "basic" | "pro" | "vip";
  name: string;
  tagline: string;
  /** Display-only marketing price (USD/month). */
  monthlyPrice: number;
  /** Fixed setup fee in USD; omit if custom (use setupNote instead). */
  setupFee?: number;
  /** Free-form setup copy, used when no fixed fee (e.g. VIP custom quote). */
  setupNote?: string;
  bullets: readonly string[];
  popular?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  id,
  name,
  tagline,
  monthlyPrice,
  setupFee,
  setupNote,
  bullets,
  popular = false,
  ctaLabel = "Calculate my price",
  ctaHref = "#calculator",
} = Astro.props;

const setupLine =
  setupFee !== undefined ? `+ $${setupFee} one-time setup` : setupNote;
---

<article
  id={`tier-${id}`}
  class:list={[
    "relative flex flex-col rounded-2xl bg-white p-8 shadow-sm ring-1 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg",
    popular
      ? "ring-2 ring-primary-600 shadow-xl lg:scale-105"
      : "ring-gray-200",
  ]}
  data-animate="fade-up"
  aria-labelledby={`tier-${id}-name`}
>
  {popular && (
    <span class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-4 py-1 text-xs font-semibold uppercase tracking-wide text-white">
      Most Popular
    </span>
  )}

  <div class="mb-6">
    <h3 id={`tier-${id}-name`} class="text-lg font-semibold text-gray-900">
      {name}
    </h3>
    <p class="mt-1 text-sm text-gray-500">{tagline}</p>
  </div>

  <div class="mb-6">
    <span class="text-4xl font-extrabold text-gray-900">${monthlyPrice}</span>
    <span class="text-base text-gray-500">/mo</span>
    {setupLine && (
      <p class="mt-1 text-xs text-gray-500">{setupLine}</p>
    )}
  </div>

  <a
    href={ctaHref}
    class:list={[
      "mb-8 block rounded-full py-3 text-center text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500",
      popular
        ? "bg-primary-600 text-white hover:bg-primary-700"
        : "border border-primary-600 text-primary-600 hover:bg-primary-50",
    ]}
  >
    {ctaLabel}
  </a>

  <ul class="flex-1 space-y-3" role="list">
    {bullets.map((bullet) => (
      <li class="flex items-start gap-3">
        <svg
          class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary-600"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d={checkPath}
          />
        </svg>
        <span class="text-sm text-gray-600">{bullet}</span>
      </li>
    ))}
  </ul>
</article>
